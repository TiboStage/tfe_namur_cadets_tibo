{% extends 'website/layout.html.twig' %}
{% trans_default_domain 'website' %}

{% block title %}{{ 'meta.contact_title'|trans }}{% endblock %}

{% block content %}
    <main class="container contact-page section-header">
        <div class="contact-grid">

            {# ══════════════════════════════════════════════════════════ #}
            {# COLONNE GAUCHE                                              #}
            {# ══════════════════════════════════════════════════════════ #}
            <div class="contact-info">
                <span class="section-tag">{{ 'contact.info.tag'|trans }}</span>
                <h1 class="main-title">
                    {{ 'contact.info.title'|trans }}<br>
                    <span class="highlight">{{ 'contact.info.title_highlight'|trans }}</span>
                </h1>
                <p class="section-desc">{{ 'contact.info.description'|trans }}</p>

                <div class="info-cards-stack">
                    <div class="info-card">
                        <div class="info-icon">
                            {{ ux_icon('lucide:clock', {class: 'icon-md'}) }}
                        </div>
                        <div class="info-content">
                            <h4>{{ 'contact.info.cards.response_time'|trans }}</h4>
                            <p>{{ 'contact.info.cards.response_desc'|trans }}<br>
                                <span>{{ 'contact.info.cards.response_sub'|trans }}</span>
                            </p>
                        </div>
                    </div>
                    <div class="info-card">
                        <div class="info-icon">
                            {{ ux_icon('lucide:graduation-cap', {class: 'icon-md'}) }}
                        </div>
                        <div class="info-content">
                            <h4>{{ 'contact.info.cards.academic'|trans }}</h4>
                            <p>{{ 'contact.info.cards.academic_desc'|trans }}<br>
                                {{ 'contact.info.cards.academic_location'|trans }}
                            </p>
                        </div>
                    </div>
                </div>

                <div class="social-links">
                    <a href="#" class="social-box">{{ ux_icon('lucide:twitter', {class: 'icon-sm'}) }}</a>
                    <a href="#" class="social-box">{{ ux_icon('lucide:instagram', {class: 'icon-sm'}) }}</a>
                    <a href="#" class="social-box">{{ ux_icon('lucide:message-circle', {class: 'icon-sm'}) }}</a>
                    <a href="#" class="social-box">{{ ux_icon('lucide:linkedin', {class: 'icon-sm'}) }}</a>
                </div>
            </div>

            {# ══════════════════════════════════════════════════════════ #}
            {# COLONNE DROITE                                              #}
            {# ══════════════════════════════════════════════════════════ #}
            <div class="form-wrapper">
                <div class="form-card">
                    <h2>{{ 'contact.form.title'|trans }}</h2>

                    {{ form_start(form, {
                        'attr': {
                            'novalidate': 'novalidate',
                            'class': 'contact-form',
                            'data-controller': 'form-validation',
                            'data-action': 'submit->form-validation#submit',
                            'data-turbo': 'false'
                        }
                    }) }}

                    {# ── Email ─────────────────────────────────── #}
                    <div class="form-group-full">
                        {{ form_row(form.email, {
                            'label': 'contact.form.labels.email'|trans,
                            'attr': {
                                'placeholder': 'contact.form.placeholders.email'|trans,
                                'data-form-validation-target': 'field',
                                'data-action': 'blur->form-validation#validate',
                                'data-error-required': 'contact.email.not_blank'|trans({}, 'validators'),
                                'data-error-email':    'contact.email.invalid'|trans({}, 'validators')
                            }
                        }) }}
                    </div>

                    {# ── Prénom & Nom ───────────────────────────── #}
                    {# minlength: 2 = identique à la contrainte Length(min: 2) dans ContactType #}
                    <div class="form-row-two">
                        {{ form_row(form.firstname, {
                            'label': 'contact.form.labels.firstname'|trans,
                            'attr': {
                                'placeholder':  'contact.form.placeholders.firstname'|trans,
                                'minlength': 2,
                                'data-form-validation-target': 'field',
                                'data-action': 'blur->form-validation#validate',
                                'data-error-required':  'contact.firstname.not_blank'|trans({}, 'validators'),
                                'data-error-minlength': 'contact.firstname.too_short'|trans({}, 'validators')
                            }
                        }) }}

                        {{ form_row(form.lastname, {
                            'label': 'contact.form.labels.lastname'|trans,
                            'attr': {
                                'placeholder':  'contact.form.placeholders.lastname'|trans,
                                'minlength': 2,
                                'data-form-validation-target': 'field',
                                'data-action': 'blur->form-validation#validate',
                                'data-error-required':  'contact.lastname.not_blank'|trans({}, 'validators'),
                                'data-error-minlength': 'contact.lastname.too_short'|trans({}, 'validators')
                            }
                        }) }}
                    </div>

                    {# ── Sujet ─────────────────────────────────── #}
                    <div class="form-group-full">
                        {{ form_row(form.subject, {
                            'label': 'contact.form.labels.subject'|trans,
                            'attr': {
                                'data-form-validation-target': 'field',
                                'data-action': 'change->form-validation#validate',
                                'data-error-required': 'contact.subject.not_blank'|trans({}, 'validators')
                            }
                        }) }}
                    </div>

                    {# ── Message ───────────────────────────────── #}
                    {# minlength: 10 = identique à la contrainte Length(min: 10) dans ContactType #}
                    <div class="form-group-full">
                        {{ form_row(form.message, {
                            'label': 'contact.form.labels.message'|trans,
                            'attr': {
                                'rows': '5',
                                'placeholder': 'contact.form.placeholders.message'|trans,
                                'minlength': 10,
                                'data-form-validation-target': 'field',
                                'data-action': 'blur->form-validation#validate',
                                'data-error-required':  'contact.message.not_blank'|trans({}, 'validators'),
                                'data-error-minlength': 'contact.message.too_short'|trans({}, 'validators')
                            }
                        }) }}
                    </div>

                    {# ── Checkbox privacy ──────────────────────── #}
                    {{ form_row(form.privacy, {
                        'label_html': true,
                        'label': 'contact.form.privacy'|trans ~ ' <a href="#">' ~ 'contact.form.privacy_link'|trans ~ '</a>.',
                        'attr': {
                            'data-form-validation-target': 'field',
                            'data-action': 'change->form-validation#validate',
                            'data-error-required': 'contact.privacy.must_agree'|trans({}, 'validators')
                        }
                    }) }}

                    <button type="submit" class="btn-primary-pricing">
                        {{ 'contact.form.submit'|trans }}
                    </button>

                    {{ form_end(form) }}
                </div>
            </div>

        </div>
    </main>
{% endblock %}
