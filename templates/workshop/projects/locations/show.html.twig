{% extends 'workshop/projects/layout.html.twig' %}
{% trans_default_domain 'workshop_interface' %}

{% block title %}{{ location.name }} — {{ project.title }}{% endblock %}

{% block project_content %}
<div class="dashboard-container">

    <header class="page-header">
        <div>
            <a href="{{ path('app_location_index', {project_slug: project.slug}) }}" class="link-back">{{ 'location.show.back'|trans }}</a>
            <h1>
                {{ location.name }}
                {% if location.type %}
                    <span class="project-type-badge">{{ location.type }}</span>
                {% endif %}
            </h1>
        </div>
        <a href="{{ path('app_location_edit', {project_slug: project.slug, id: location.id}) }}" class="btn-export">
            {{ 'location.show.edit_btn'|trans }}
        </a>
    </header>

    <div class="character-show-grid">

        <div class="character-main">
            {% if location.description %}
                <div class="profile-section">
                    <div class="profile-section-header"><h2>{{ 'location.form.description'|trans }}</h2></div>
                    <p>{{ location.description }}</p>
                </div>
            {% else %}
                <div class="profile-section">
                    <p class="text-muted">{{ 'location.show.no_description'|trans }}</p>
                </div>
            {% endif %}
        </div>

        <aside class="character-sidebar">
            <div class="profile-section">
                <div class="profile-section-header"><h2>{{ 'location.info.title'|trans }}</h2></div>
                <div class="stat-row">
                    <span class="text-muted">{{ 'location.info.type'|trans }}</span>
                    <span>{{ location.type|default('—') }}</span>
                </div>
                <div class="stat-row">
                    <span class="text-muted">{{ 'location.info.created_at'|trans }}</span>
                    <span>{{ location.createdAt|date('d/m/Y') }}</span>
                </div>
                <div class="stat-row">
                    <span class="text-muted">{{ 'location.info.updated_at'|trans }}</span>
                    <span>{{ location.updatedAt|date('d/m/Y') }}</span>
                </div>
            </div>
        </aside>

    </div>
</div>
{% endblock %}
