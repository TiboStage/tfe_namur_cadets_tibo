{# templates/modo/project_show.html.twig #}
{% extends 'modo/layout.html.twig' %}

{% block title %}Modo — {{ project.title }}{% endblock %}
{% block modo_title %}Examen du projet{% endblock %}

{% block modo_content %}

    <div class="admin-detail-header">
        <div>
            <h2>{{ project.title }}
                <span class="mod-badge mod-badge--{{ project.moderationStatus }}">{{ project.moderationStatus }}</span>
            </h2>
            <p class="text-muted">Par <strong>{{ project.createdBy.username }}</strong> · {{ project.projectType|upper }}</p>
        </div>
        <a href="{{ path('modo_reports', {_locale: app.request.locale}) }}" class="btn-table">← Retour</a>
    </div>

    <div class="aup-grid">

        <div class="panel-box">
            <h3>Informations</h3>
            <dl class="admin-dl">
                <dt>Titre</dt><dd>{{ project.title }}</dd>
                <dt>Description</dt><dd>{{ project.description ?: '—' }}</dd>
                <dt>Visibilité</dt><dd>{{ project.visibility == 'public' ? 'En ligne' : (project.visibility == 'private' ? 'Privé' : 'Non publié') }}</dd>
                <dt>Signalements</dt><dd>{{ project.reportCount }}</dd>
                <dt>Créé le</dt><dd>{{ project.createdAt|date('d/m/Y') }}</dd>
                <dt>Modifié le</dt><dd>{{ project.updatedAt|date('d/m/Y H:i') }}</dd>
            </dl>
        </div>

        <div class="panel-box">
            <h3>Décision de modération</h3>
            <p class="text-muted text-base mb-5">
                En tant que modérateur, vous pouvez lever le signalement, émettre un avertissement ou bloquer ce projet.
                L'approbation définitive est réservée aux administrateurs.
            </p>

            <form method="post"
                  action="{{ path('modo_project_review', {id: project.id, _locale: app.request.locale}) }}"
                  onsubmit="return confirm('Confirmer cette action de modération ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('modo_review_' ~ project.id) }}">
                <div class="mod-actions">
                    <button type="submit" name="status" value="clear"
                            class="btn-table btn-table--success {{ project.moderationStatus == 'clear' ? 'btn-table--current' : '' }}">
                        ✓ Lever le signalement (clear)
                    </button>
                    <button type="submit" name="status" value="warning"
                            class="btn-table btn-table--warn {{ project.moderationStatus == 'warning' ? 'btn-table--current' : '' }}">
                        ⚠ Émettre un avertissement (warning)
                    </button>
                    <button type="submit" name="status" value="blocked"
                            class="btn-table btn-table--danger {{ project.moderationStatus == 'blocked' ? 'btn-table--current' : '' }}">
                        ✕ Bloquer le projet (blocked)
                    </button>
                </div>
            </form>
        </div>

    </div>

{% endblock %}
