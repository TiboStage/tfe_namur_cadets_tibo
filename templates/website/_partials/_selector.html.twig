
<div class="footer-bottom-bar">
    <div class="footer-container bottom-flex">

        {# Sélecteur de Langue avec Stimulus #}
        <div class="language-selector"
             data-controller="language"
             data-action="click@window->language#close">

            <button class="language-toggle" data-action="language#toggle" aria-label="Changer de langue">
                    <span class="current-lang">
                        {% if app.request.locale == 'fr' %}
                            🇫🇷 Français
                        {% elseif app.request.locale == 'en' %}
                            🇬🇧 English
                        {% elseif app.request.locale == 'nl' %}
                            🇳🇱 Nederlands
                        {% endif %}
                    </span>

                {{ ux_icon('lucide:chevron-down', { class: 'icon-xs', 'data-language-target': 'arrow' }) }}
            </button>

            <div class="language-dropdown hidden" data-language-target="dropdown">
                {% set current_route = app.request.attributes.get('_route')|default('app_home') %}
                {% set current_params = app.request.attributes.get('_route_params')|default({}) %}

                {# Français #}
                <a href="{{ path(current_route, current_params|merge({'_locale': 'fr'})) }}"
                   class="language-option {% if app.request.locale == 'fr' %}active{% endif %}">
                    <span class="lang-flag">🇫🇷</span>
                    <div class="lang-info">
                        <span class="lang-name">Français</span>
                        <span class="lang-region">Belgique</span>
                    </div>
                </a>

                {# Anglais #}
                <a href="{{ path(current_route, current_params|merge({'_locale': 'en'})) }}"
                   class="language-option {% if app.request.locale == 'en' %}active{% endif %}">
                    <span class="lang-flag">🇬🇧</span>
                    <div class="lang-info">
                        <span class="lang-name">English</span>
                        <span class="lang-region">International</span>
                    </div>
                </a>

                {# Néerlandais #}
                <a href="{{ path(current_route, current_params|merge({'_locale': 'nl'})) }}"
                   class="language-option {% if app.request.locale == 'nl' %}active{% endif %}">
                    <span class="lang-flag">🇳🇱</span>
                    <div class="lang-info">
                        <span class="lang-name">Nederlands</span>
                        <span class="lang-region">België</span>
                    </div>
                </a>
            </div>
        </div>

        <p class="copyright">
            © 2026 — TFE — EAFC Namur Cadets — Thibault Claerhoudt
        </p>

        <span class="version-badge">v0.6.1</span>
    </div>
</div>
