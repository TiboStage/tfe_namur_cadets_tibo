{% extends 'workshop/projects/layout.html.twig' %}
{% trans_default_domain 'workshop' %}

{% block title %}{{ 'location.edit.title'|trans }} — {{ location.name }} — {{ project.title }}{% endblock %}

{% block project_content %}
<div class="workshop-container">

    {# ── En-tête page (accès direct uniquement) ────────────────────── #}
    <header class="page-header">
        <div>
            <a href="{{ path('app_location_show', {project_slug: project.slug, id: location.id}) }}" class="link-back">
                {{ ux_icon('lucide:arrow-left', {class: 'icon-xs'}) }}
                {{ location.name }}
            </a>
            <h1>{{ 'location.edit.title'|trans }}</h1>
        </div>
    </header>

    <div class="form-page-wrapper" data-controller="advanced-form">

        {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'project-form'}}) }}

        <div class="form-section">
            {{ form_row(form.name, {'label': 'location.form.name'|trans, 'attr': {'autofocus': true}}) }}
            {{ form_row(form.type, {'label': 'location.form.type'|trans}) }}
        </div>

        <label class="advanced-toggle">
            <input type="checkbox"
                   class="advanced-toggle__checkbox"
                   data-advanced-form-target="checkbox"
                   data-action="change->advanced-form#toggle">
            <span class="advanced-toggle__label">
                {{ ux_icon('lucide:settings-2', {style: 'width:13px;height:13px'}) }}
                {{ 'location.edit.advanced'|trans }}
            </span>
        </label>

        <div data-advanced-form-target="panel" hidden>
            <div class="advanced-panel">
                <div class="advanced-panel__section">
                    {{ form_row(form.description, {'label': 'location.form.description'|trans, 'attr': {'rows': 4}}) }}
                </div>
            </div>
        </div>

        <div class="form-actions">
            <a href="{{ path('app_location_show', {project_slug: project.slug, id: location.id}) }}" class="btn-export">
                {{ 'location.edit.cancel'|trans }}
            </a>
            <button type="submit" class="btn-creat">{{ 'location.edit.submit'|trans }}</button>
        </div>

        {{ form_end(form) }}

        <div class="danger-zone">
            <div class="danger-zone-header">
                <h3>{{ 'location.edit.danger_zone'|trans }}</h3>
                <p>{{ 'location.edit.danger_desc'|trans }}</p>
            </div>
            <form method="post"
                  action="{{ path('app_location_delete', {project_slug: project.slug, id: location.id}) }}"
                  data-turbo-confirm="{{ 'location.edit.delete_confirm'|trans }}">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_location_' ~ location.id) }}">
                <button type="submit" class="btn-danger">{{ 'location.edit.delete_btn'|trans }}</button>
            </form>
        </div>

    </div>

</div>
{% endblock %}
