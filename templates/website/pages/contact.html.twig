{% extends 'website/layout.html.twig' %}

{% trans_default_domain 'contact' %}

{% block title %}{{ 'meta.title'|trans }}{% endblock %}

{% block content %}
    <main class="container contact-page section-header">
        <div class="contact-grid">

            {# Partie Gauche : Infos #}
            <div class="contact-info">
                <span class="section-tag">{{ 'info.tag'|trans }}</span>
                <h1 class="main-title">{{ 'info.title'|trans }} <br><span class="highlight">{{ 'info.title_highlight'|trans }}</span></h1>
                <p class="section-desc">{{ 'info.description'|trans }}</p>

                <div class="info-cards-stack">
                    <div class="info-card">
                        <div class="info-icon"><i class="fa-regular fa-clock"></i></div>
                        <div class="info-content">
                            <h4>{{ 'info.cards.response_time'|trans }}</h4>
                            <p>{{ 'info.cards.response_desc'|trans }}<br><span>{{ 'info.cards.response_sub'|trans }}</span></p>
                        </div>
                    </div>
                    <div class="info-card">
                        <div class="info-icon"><i class="fa-solid fa-graduation-cap"></i></div>
                        <div class="info-content">
                            <h4>{{ 'info.cards.academic'|trans }}</h4>
                            <p>{{ 'info.cards.academic_desc'|trans }}<br>{{ 'info.cards.academic_location'|trans }}</p>
                        </div>
                    </div>
                </div>

                <div class="social-links">
                    <a href="#" class="social-box"><i class="fa-brands fa-x-twitter"></i></a>
                    <a href="#" class="social-box"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#" class="social-box"><i class="fa-brands fa-discord"></i></a>
                    <a href="#" class="social-box"><i class="fa-brands fa-linkedin-in"></i></a>
                </div>
            </div>

            {# Partie Droite : Formulaire #}
            <div class="form-wrapper">
                <div class="form-card">
                    <h2 class="form-title">{{ 'form.title'|trans }}</h2>

                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            {{ component('Alert', { type: label, message: message }) }}
                        {% endfor %}
                    {% endfor %}

                    {# On garde le controller uniquement ici #}
                    <form action="{{ path('app_contact') }}"
                          method="POST"
                          class="scenart-form"
                          novalidate
                          data-controller="validator"
                          data-validator-error-value="{{ 'form.errors.global_invalid'|trans }}"
                          data-action="submit->validator#validateForm">

                        {# Champ Email #}
                        <div class="form-group full">
                            <label for="email">
                                {{ 'form.labels.email'|trans }} <span>*</span>
                                <span class="error-message d-none text-danger small"> {{ 'form.errors.email_invalid'|trans }}</span>
                            </label>
                            <div class="input-wrapper" style="position: relative;">
                                <input type="email" id="email" name="email" placeholder="john.doe@scenart.be" data-action="blur->validator#check">
                                <span class="success-icon d-none" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%);">
                                    {{ ux_icon('lucide:check-circle', {class: 'text-success', style: 'width: 20px; height: 20px;'}) }}
                                </span>
                                <span class="error-icon d-none" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%);">
                                    {{ ux_icon('lucide:alert-circle', {class: 'text-danger', style: 'width: 20px; height: 20px;'}) }}
                                </span>
                            </div>
                        </div>

                        <div class="form-row">
                            {# Champ Prénom #}
                            <div class="form-group">
                                <label for="firstname">
                                    {{ 'form.labels.firstname'|trans }} <span>*</span>
                                    <span class="error-message d-none text-danger small"> {{ 'form.errors.required'|trans }}</span>
                                </label>
                                <div class="input-wrapper" style="position: relative;">
                                    <input type="text" id="firstname" name="firstname" placeholder="{{ 'form.placeholders.firstname'|trans }}" data-action="blur->validator#check">
                                    <span class="success-icon d-none" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%);">
                                        {{ ux_icon('lucide:check-circle', {class: 'text-success', style: 'width: 20px; height: 20px;'}) }}
                                    </span>
                                    <span class="error-icon d-none" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%);">
                                        {{ ux_icon('lucide:alert-circle', {class: 'text-danger', style: 'width: 20px; height: 20px;'}) }}
                                    </span>
                                </div>
                            </div>

                            {# Champ Nom #}
                            <div class="form-group">
                                <label for="lastname">
                                    {{ 'form.labels.lastname'|trans }} <span>*</span>
                                    <span class="error-message d-none text-danger small"> {{ 'form.errors.required'|trans }}</span>
                                </label>
                                <div class="input-wrapper" style="position: relative;">
                                    <input type="text" id="lastname" name="lastname" placeholder="{{ 'form.placeholders.lastname'|trans }}" data-action="blur->validator#check">
                                    <span class="success-icon d-none" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%);">
                                        {{ ux_icon('lucide:check-circle', {class: 'text-success', style: 'width: 20px; height: 20px;'}) }}
                                    </span>
                                    <span class="error-icon d-none" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%);">
                                        {{ ux_icon('lucide:alert-circle', {class: 'text-danger', style: 'width: 20px; height: 20px;'}) }}
                                    </span>
                                </div>
                            </div>
                        </div>

                        {# Champ Sujet #}
                        <div class="form-group full">
                            <label for="subject">
                                {{ 'form.labels.subject'|trans }} <span>*</span>
                                <span class="error-message d-none text-danger small"> {{ 'form.errors.subject_required'|trans }}</span>
                            </label>
                            <div class="select-wrapper" style="position: relative;">
                                <select name="subject" id="subject" data-action="change->validator#check">
                                    <option value="" disabled selected>{{ 'form.placeholders.subject'|trans }}</option>
                                    <option value="support">{{ 'form.subjects.support'|trans }}</option>
                                    <option value="billing">{{ 'form.subjects.billing'|trans }}</option>
                                    <option value="partnership">{{ 'form.subjects.partnership'|trans }}</option>
                                </select>
                                <span class="success-icon d-none" style="position: absolute; right: 35px; top: 50%; transform: translateY(-50%);">
                                    {{ ux_icon('lucide:check-circle', {class: 'text-success', style: 'width: 20px; height: 20px;'}) }}
                                </span>
                                <span class="error-icon d-none" style="position: absolute; right: 35px; top: 50%; transform: translateY(-50%);">
                                    {{ ux_icon('lucide:alert-circle', {class: 'text-danger', style: 'width: 20px; height: 20px;'}) }}
                                </span>
                            </div>
                        </div>

                        {# Champ Message #}
                        <div class="form-group full">
                            <label for="message">
                                {{ 'form.labels.message'|trans }} <span>*</span>
                                <span class="error-message d-none text-danger small"> {{ 'form.errors.message_short'|trans }}</span>
                            </label>
                            <div class="input-wrapper" style="position: relative;">
                                <textarea id="message" name="message" rows="5" placeholder="{{ 'form.placeholders.message'|trans }}" data-action="blur->validator#check"></textarea>
                                <span class="success-icon d-none" style="position: absolute; right: 15px; top: 20px;">
                                    {{ ux_icon('lucide:check-circle', {class: 'text-success', style: 'width: 20px; height: 20px;'}) }}
                                </span>
                                <span class="error-icon d-none" style="position: absolute; right: 15px; top: 20px;">
                                    {{ ux_icon('lucide:alert-circle', {class: 'text-danger', style: 'width: 20px; height: 20px;'}) }}
                                </span>
                            </div>
                        </div>

                        {# AJOUT : Case Privacy Policy (Indispensable pour la validation serveur) #}
                        <div class="form-checkbox">
                            <input type="checkbox" name="privacy" id="privacy" data-action="change->validator#check">
                            <label for="privacy">
                                {{ 'form.privacy'|trans }} <a href="#">{{ 'form.privacy_link'|trans }}</a>.
                                <span class="error-message d-none text-danger small"> {{ 'form.errors.privacy_required'|trans }}</span>
                            </label>
                        </div>

                        <button type="submit" class="btn-primary-pricing">{{ 'form.submit'|trans }}</button>
                    </form>
                </div>
            </div>

        </div>
    </main>
{% endblock %}
