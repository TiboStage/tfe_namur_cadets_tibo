{% trans_default_domain 'workshop' %}

<aside class="workspace-sidebar">

    {# ── Header avec project switcher dropdown ────────────── #}
    <div class="sidebar-header">
        <div class="project-switcher" data-controller="dropdown">

            <button class="project-switcher-btn"
                    data-action="click->dropdown#toggle"
                    type="button">
                <span class="project-icon">{{ project.title|first|upper }}</span>
                <span class="project-name">{{ project.title }}</span>
                {{ ux_icon('lucide:chevron-down', {class: 'icon-xs'}) }}
            </button>

            {# Le controller dropdown toggle .show sur cet élément #}
            <div class="project-switcher-dropdown" data-dropdown-target="menu">

                <div class="dropdown-header">
                    {{ 'navbar.recent_projects'|trans }}
                </div>

                <div class="dropdown-projects">

                    {# Projet actuel #}
                    <div class="dropdown-project-item current">
                        <span class="project-icon-sm">{{ project.title|first|upper }}</span>
                        <div class="project-info">
                            <span class="project-title">{{ project.title }}</span>
                            <span class="project-meta">{{ project.projectType }}</span>
                        </div>
                        <span class="badge-current">{{ 'navbar.current_badge'|trans }}</span>
                    </div>

                    {# Autres projets (max 4, exclu le projet actuel) #}
                    {% for other_project in app.user.projects %}
                        {% if other_project.id != project.id %}
                            <a href="{{ path('app_project_show', {slug: other_project.slug}) }}"
                               class="dropdown-project-item">
                                <span class="project-icon-sm">{{ other_project.title|first|upper }}</span>
                                <div class="project-info">
                                    <span class="project-title">{{ other_project.title }}</span>
                                    <span class="project-meta">{{ other_project.projectType }}</span>
                                </div>
                            </a>
                        {% endif %}
                    {% endfor %}

                </div>

                <div class="dropdown-footer">
                    <a href="{{ path('app_project_index') }}" class="dropdown-link">
                        {{ ux_icon('lucide:folder', {class: 'icon-xs'}) }}
                        {{ 'dashboard.recent_projects.view_all'|trans }}
                    </a>
                </div>

            </div>
        </div>
    </div>

    {# ── Bouton Administration ──────────────────────────── #}
    {% if is_granted('ROLE_ADMIN') %}
        <div class="sidebar-admin">
            <a href="{{ path('admin_dashboard') }}" class="admin-btn">
                {{ ux_icon('lucide:shield-alert') }}
                Administration
                {{ ux_icon('lucide:external-link') }}
            </a>
        </div>
    {% endif %}

    {# ── Navigation principale ──────────────────────────── #}
    <nav class="sidebar-nav">

        {# Section ÉCRITURE #}
        <div class="nav-group">
            <span class="nav-label">Écriture</span>

            <a href="{{ path('app_project_show', {slug: project.slug}) }}"
               class="nav-item {{ app.request.attributes.get('_route') == 'app_project_show' ? 'active' : '' }}">
                {{ ux_icon('lucide:layout-grid') }}
                Aperçu
            </a>

            <a href="{{ path('app_manuscript_index', {project_slug: project.slug}) }}"
               class="nav-item {{ app.request.attributes.get('_route') starts with 'app_manuscript' ? 'active' : '' }}">
                {{ ux_icon('lucide:book-open') }}
                Manuscript
                {{ ux_icon('lucide:corner-right-down', {class: 'nav-action'}) }}
            </a>
            <a href="#" class="nav-item">{{ ux_icon('lucide:network') }}Structure</a>
{#            <a href="{{ path('app_structure_index', {project_slug: project.slug}) }}"#}
{#               class="nav-item {{ app.request.attributes.get('_route') starts with 'app_structure' ? 'active' : '' }}">#}
{#                {{ ux_icon('lucide:network') }}#}
{#                Structure#}
{#            </a>#}
        </div>

        {# Section UNIVERS #}
        <div class="nav-group">
            <span class="nav-label">Univers</span>

            <a href="{{ path('app_character_index', {project_slug: project.slug}) }}"
               class="nav-item {{ app.request.attributes.get('_route') starts with 'app_character' ? 'active' : '' }}">
                {{ ux_icon('lucide:user') }}
                Personnage
                <span class="nav-badge">{{ project.characters|length }}</span>
            </a>

            <a href="{{ path('app_location_index', {project_slug: project.slug}) }}"
               class="nav-item {{ app.request.attributes.get('_route') starts with 'app_location' ? 'active' : '' }}">
                {{ ux_icon('lucide:map-pin') }}
                Lieux
                <span class="nav-badge">{{ project.locations|length }}</span>
            </a>

            <a href="#" class="nav-item">{{ ux_icon('lucide:git-branch') }}Relation</a>
            {#            <a href="{{ path('app_relation_index', {project_slug: project.slug}) }}"#}
{#               class="nav-item {{ app.request.attributes.get('_route') starts with 'app_relation' ? 'active' : '' }}">#}
{#                {{ ux_icon('lucide:git-branch') }}#}
{#                Relations#}
{#            </a>#}

            <a href="#" class="nav-item">{{ ux_icon('lucide:file-text') }}Documentation</a>
            {#            <a href="{{ path('app_documentation_index', {project_slug: project.slug}) }}"#}
{#               class="nav-item {{ app.request.attributes.get('_route') starts with 'app_documentation' ? 'active' : '' }}">#}
{#                {{ ux_icon('lucide:file-text') }}#}
{#                Documentation#}
{#            </a>#}
        </div>

        {# Section PRODUCTION #}
        <div class="nav-group">
            <span class="nav-label">Production</span>


            <a href="#" class="nav-item">{{ ux_icon('lucide:check-check') }}Taches
                <span class="nav-badge">2</span>
            </a>

            <a href="{{ path('app_task_index', {project_slug: project.slug}) }}"
               class="nav-item {{ app.request.attributes.get('_route') starts with 'app_task' ? 'active' : '' }}">
                {{ ux_icon('lucide:check-square') }}
                Tâches
                <span class="nav-badge">{{ project.tasks|filter(t => not t.completed)|length }}</span>
            </a>

{#            <a href="#" class="nav-item">{{ ux_icon('lucide:file-edit') }}Notes</a>#}

            <a href="{{ path('app_note_index', {project_slug: project.slug}) }}"
               class="nav-item {{ app.request.attributes.get('_route') starts with 'app_note' ? 'active' : '' }}">
                {{ ux_icon('lucide:file-edit') }}
                Notes
            </a>
        </div>

    </nav>

    {# ── Footer ─────────────────────────────────────────── #}
    <footer class="sidebar-footer">

        <a href="#" class="nav-item">{{ ux_icon('lucide:settings') }}Paramètre du projet</a>

        {#        <a href="{{ path('app_project_settings', {slug: project.slug}) }}" class="footer-settings">#}
{#            {{ ux_icon('lucide:settings') }}#}
{#            Paramètres projet#}
{#        </a>#}
        <span class="sidebar-version">Version {{ app_version.version }}</span>
    </footer>

</aside>
