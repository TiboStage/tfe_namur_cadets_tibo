{% extends 'base.html.twig' %}

{# ══════════════════════════════════════════════════════════
   LAYOUT WORKSPACE PROJET

   Ce layout affiche :
   - Sidebar projet (gauche)
   - Zone de contenu (droite)

   La navbar principale (Mes projets, etc.) n'est PAS affichée
   ══════════════════════════════════════════════════════════ #}

{% block body_class %}workspace-layout{% endblock %}


{% block body %}
{# ══════════════════════════════════════════════════════════
   Le data-controller="modal" doit englober TOUT le contenu
   pour que les data-action="click->modal#open" des triggers
   puissent remonter jusqu'à lui via la chaîne d'ancêtres.
   ══════════════════════════════════════════════════════════ #}
<div data-controller="modal">

    {% include 'workshop/_partials/_topbar.html.twig' %}

    <div class="workspace-container">

        {# ── SIDEBAR (navigation projet) ───────────────────── #}
        {% include 'workshop/_partials/_project_nav.html.twig' %}

        {# ── CONTENT AREA ──────────────────────────────────── #}
        <main class="workspace-main">

            {# Contenu de la page projet #}
            {% block project_content %}{% endblock %}

        </main>

    </div>

    {# ══════════════════════════════════════════════════════════
       MODAL GLOBAL — overlay cible du controller
       data-modal-target="overlay" permet au controller de
       manipuler cet élément via this.overlayTarget
       ══════════════════════════════════════════════════════════ #}
    <div class="ws-modal"
         data-modal-target="overlay"
         data-action="click->modal#backdropClick">
        <div class="ws-modal-box">
            <button type="button"
                    class="ws-modal-close-btn"
                    data-action="modal#close"
                    aria-label="Fermer">
                {{ ux_icon('lucide:x', {class: 'icon-sm'}) }}
            </button>
            <turbo-frame id="modal-frame">
                <div class="ws-modal-loading">
                    <span class="ws-modal-spinner"></span>
                </div>
            </turbo-frame>
        </div>
    </div>

</div>
{% endblock %}
