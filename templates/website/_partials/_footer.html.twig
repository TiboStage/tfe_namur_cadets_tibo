<footer class="main-footer">
    <div class="footer-container">
        <div class="footer-content">
            {# Colonne 1 #}
            <div class="footer-column">
                <h4>Produit</h4>
                <a href="{{ path('app_features') }}">Fonctionnalités</a>
                <a href="{{ path('app_pricing') }}">Tarifs</a>
                <a href="{{ path('app_examples') }}">Exemples</a>
                <a href="#">Changelog</a>
            </div>

            {# Colonne 2 #}
            <div class="footer-column">
                <h4>Ressources</h4>
                <a href="#">Documentation</a>
                <a href="#">Template</a>
                <a href="#">Tutoriels</a>
                <a href="#">Blog</a>
            </div>

            {# Colonne 3 #}
            <div class="footer-column">
                <h4>Légal</h4>
                <a href="#">CGU</a>
                <a href="#">Confidentialité</a>
                <a href="#">Cookies</a>
                <a href="{{ path('app_contact') }}">Contact</a>
            </div>
        </div>
    </div>

    <div class="footer-bottom-bar">
        <div class="footer-container bottom-flex">
            {# Sélecteur de Langue #}
            <div class="language-selector">
                <i class="fa-solid fa-globe"></i>
                <div class="lang-links">
                    <a href="{{ path(app.request.attributes.get('_route')|default('app_home'), app.request.attributes.get('_route_params')|merge({'_locale': 'fr'})) }}"
                       class="lang-link {% if app.request.locale == 'fr' %}active{% endif %}">FR</a>

                    <span class="separator">/</span>

                    <a href="{{ path(app.request.attributes.get('_route')|default('app_home'), app.request.attributes.get('_route_params')|merge({'_locale': 'en'})) }}"
                       class="lang-link {% if app.request.locale == 'en' %}active{% endif %}">EN</a>
                </div>
            </div>

            <p class="copyright">© 2026 — TFE — EAFC Namur Cadets — Thibault Claerhoudt</p>
            <p class="designer-credit">Design & Développement par <span class="highlight">Thibault CLAERHOUDT</span></p>
        </div>
    </div>
</footer>
