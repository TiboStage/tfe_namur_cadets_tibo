<!DOCTYPE html>
<html lang="{{ locale|default('fr') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>403 — {{ 'error_403.title'|trans({}, 'errors', locale|default('fr')) }} · Scénart</title>
    {{ importmap('app') }}
</head>
<body>
<div class="error-page">
    <div class="error-content">

        <a href="/" class="error-logo">SCÉN<span class="highlight">ART</span></a>

        <div class="error-code">403</div>
        <h1 class="error-title">{{ 'error_403.title'|trans({}, 'errors', locale) }}</h1>
        <p class="error-desc">{{ 'error_403.desc'|trans({}, 'errors', locale) }}</p>

        <div class="error-actions">
            <a href="javascript:history.back()" class="btn-outline">
                {{ 'error_403.btn_back'|trans({}, 'errors', locale) }}
            </a>
            <a href="/{{ locale }}/atelier" class="btn-primary">
                {{ 'error_403.btn_workshop'|trans({}, 'errors', locale) }}
            </a>
        </div>

    </div>
</div>
</body>
</html>
