{# templates/admin/config.html.twig #}
{% extends 'admin/layout.html.twig' %}

{% block title %}Admin — Configuration{% endblock %}
{% block admin_title %}Configuration de la plateforme{% endblock %}

{% block admin_content %}

    <div class="aup-grid">

        <div class="panel-box">
            <h3>{{ 'config.platform_info'|trans({}, 'admin') }}</h3>
            <dl class="admin-dl">
                <dt>{{ 'config.field_name'|trans({}, 'admin') }}</dt><dd>ScénArt</dd>
                <dt>{{ 'config.field_version'|trans({}, 'admin') }}</dt><dd>1.0.0 — TFE 2026</dd>
                <dt>{{ 'config.field_framework'|trans({}, 'admin') }}</dt><dd>Symfony 8 / PHP 8.4</dd>
                <dt>{{ 'config.field_database'|trans({}, 'admin') }}</dt><dd>PostgreSQL</dd>
                <dt>{{ 'config.field_environment'|trans({}, 'admin') }}</dt><dd><code>{{ app.environment }}</code></dd>
                <dt>{{ 'config.field_debug'|trans({}, 'admin') }}</dt><dd>{{ app.debug ? 'config.debug_enabled'|trans({}, 'admin') : 'config.debug_disabled'|trans({}, 'admin') }}</dd>
            </dl>
        </div>

        <div class="panel-box">
            <h3>{{ 'config.sessions'|trans({}, 'admin') }}</h3>
            <p class="text-muted text-base mb-4">{{ 'config.sessions_hint'|trans({}, 'admin') }}</p>
            <dl class="admin-dl">
                <dt>{{ 'config.field_logged_as'|trans({}, 'admin') }}</dt><dd>{{ app.user.username }}</dd>
                <dt>{{ 'config.field_email'|trans({}, 'admin') }}</dt><dd>{{ app.user.email }}</dd>
                <dt>{{ 'config.field_roles'|trans({}, 'admin') }}</dt>
                <dd>
                    {% for role in app.user.roles %}
                        <span class="role-badge role-badge--{{ role|lower|replace({'role_': ''}) }}">{{ role|replace({'ROLE_': ''}) }}</span>
                    {% endfor %}
                </dd>
            </dl>
        </div>

        <div class="panel-box col-full">
            <h3>{{ 'config.todo_section'|trans({}, 'admin') }}</h3>
            <p class="text-muted text-base lh-loose">
                {{ 'config.todo_description'|trans({}, 'admin') }}
            </p>
        </div>

    </div>

{% endblock %}
