{#
    Carte projet skeleton — utilisée pendant le chargement / redirect per_page.
    Reproduit la structure de _project_card_private.html.twig.
#}
<article class="sc-card sc-card--skeleton">

    {# Header #}
    <div class="sc-card__header">
        <span class="sk-block sk-block--xs sk-block--w-55"></span>
        <span class="sk-block sk-block--xs sk-block--w-48"></span>
    </div>

    {# Zone image #}
    <div class="sc-card__media sk-media"></div>

    {# Corps #}
    <div class="sc-card__body">
        <div class="sk-block sk-block--title"></div>
        <div class="sk-block sk-block--xs sk-block--w-70p"></div>

        {# Status box #}
        <div class="sc-card__status-box">
            <div class="sk-block sk-block--sm"></div>
            <div class="sk-block sk-block--bar"></div>
            <div class="sk-block sk-block--xs sk-block--w-50p"></div>
        </div>

        <div class="sc-card__divider"></div>

        {# Footer #}
        <div class="sc-card__footer">
            <span class="sk-block sk-block--xs sk-block--w-60"></span>
            <span class="sk-block sk-block--xs sk-block--w-80"></span>
        </div>
    </div>

</article>
