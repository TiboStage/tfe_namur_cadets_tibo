{# templates/modo/layout.html.twig #}
{% extends 'base.html.twig' %}

{% set current_route = app.request.attributes.get('_route') %}

{% block body %}
    <div class="admin-layout admin-layout--modo">

        {# SIDEBAR ──────────────────────────────────────────────────── #}
        <aside class="admin-sidebar">
            <div class="sidebar-brand">
                <span class="brand-dot brand-dot--modo"></span>
                <span>Scénart <span class="brand-badge brand-badge--modo">Modo</span></span>
            </div>

            <nav class="sidebar-menu">
                <a href="{{ path('modo_dashboard', {_locale: app.request.locale}) }}"
                   class="menu-item {{ current_route == 'modo_dashboard' ? 'active' : '' }}">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    <span>Vue d'ensemble</span>
                </a>
                <a href="{{ path('modo_reports', {_locale: app.request.locale}) }}"
                   class="menu-item {{ current_route == 'modo_reports' or current_route == 'modo_project_show' ? 'active' : '' }}">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                    <span>Projets signalés</span>
                    {% if count_flagged is defined and count_flagged > 0 %}
                        <span class="badge-count">{{ count_flagged }}</span>
                    {% endif %}
                </a>

                <a href="{{ path('modo_report_list', {_locale: app.request.locale}) }}"
                   class="menu-item alert-item {{ current_route starts with 'modo_report' and current_route != 'modo_reports' ? 'active' : '' }}">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    <span>Signalements</span>
                    {% if count_pending_reports is defined and count_pending_reports > 0 %}
                        <span class="badge-count">{{ count_pending_reports }}</span>
                    {% endif %}
                </a>

                <a href="{{ path('modo_comments', {_locale: app.request.locale}) }}"
                   class="menu-item {{ current_route starts with 'modo_comment' ? 'active' : '' }}">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    <span>Commentaires</span>
                </a>
            </nav>

            {# Lien admin si l'utilisateur est aussi admin #}
            {% if is_granted('ROLE_ADMIN') %}
                <div class="sidebar-footer">
                    <a href="{{ path('admin_dashboard', {_locale: app.request.locale}) }}" class="sidebar-modo-link">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                        Panel Admin
                    </a>
                </div>
            {% endif %}
        </aside>

        {# CONTENU ───────────────────────────────────────────────────── #}
        <div class="admin-main">
            <header class="admin-navbar">
                <div class="navbar-left">
                    <h2>{% block modo_title %}Panel Modérateur{% endblock %}</h2>
                </div>
                <div class="navbar-right">
                    <span class="admin-user-pill admin-user-pill--modo">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        {{ app.user.username ?? 'Modo' }}
                    </span>
                    <a href="{{ path('app_workshop_dashboard') }}" class="btn-exit-admin" data-turbo="false">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Quitter
                    </a>
                </div>
            </header>

            <main class="admin-content-view">
                {% for flash_type, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="admin-flash admin-flash--{{ flash_type }}">{{ message }}</div>
                    {% endfor %}
                {% endfor %}

                {% block modo_content %}{% endblock %}
            </main>
        </div>

    </div>
{% endblock %}
