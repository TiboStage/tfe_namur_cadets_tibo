{% extends 'workshop/projects/layout.html.twig' %}
{% trans_default_domain 'workshop' %}

{% block title %}{{ 'location.index.title'|trans }} — {{ project.title }}{% endblock %}

{% block project_content %}
<div class="workshop-container">

    <header class="page-header">
        <div>
            <h1>{{ 'location.index.title'|trans }} <span class="text-muted">{{ locations|length }}</span></h1>
        </div>
        {% if not (readonly ?? false) %}
        <a href="{{ path('app_location_new', {project_slug: project.slug}) }}"
           class="btn-creat"
           data-turbo-frame="modal-frame"
           data-action="click->modal#open">
            {{ 'location.index.new_btn'|trans }}
        </a>
        {% endif %}
    </header>

    {% if locations is empty %}
        <div class="no-items">
            <p class="text-muted">{{ 'location.index.empty'|trans }}</p>
        </div>
    {% else %}
        <div class="characters-grid">
            {% for location in locations %}
                <a href="{{ path('app_location_show', {project_slug: project.slug, id: location.id}) }}" class="character-card">
                    <div class="character-card-avatar">
                        {{ location.name|first|upper }}
                    </div>
                    <div class="character-card-info">
                        <span class="character-card-name">{{ location.name }}</span>
                        <span class="character-card-role text-muted">{{ location.type|default('—') }}</span>
                    </div>
                    <span class="project-type-badge">{{ location.type }}</span>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
