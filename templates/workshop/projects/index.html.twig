{% extends 'workshop/layout.html.twig' %}

{% block content %}

    <div class="wksh-container">
        <div class="title-projects">
            {# 1. Header de la page #}
            <div>
                <h1>Mes projets</h1>
                <p class="text-muted">{{ projects|length }} projet(s) au total</p>
            </div>

            {# 2. Barre d'actions #}
            <div class="view-actions" data-controller="view-switcher">
                <div class="btn-group">
                    <button class="btn btn--sm active" data-action="click->view-switcher#switch" data-view="grid">
                        {{ ux_icon('lucide:layout-grid') }}
                    </button>
                    <button class="btn btn--sm" data-action="click->view-switcher#switch" data-view="list">
                        {{ ux_icon('lucide:list') }}
                    </button>
                </div>
            </div>
        </div>


        {# 3. Conteneur principal #}
        <div id="projects-container" class="projects-grid">

            {# Header du Tableau (Visible uniquement en mode liste) #}
            <div class="project-list-header">
                <div class="col-main">Projets</div>
                <div class="col-status">Status</div>
                <div class="col-progression">Progression</div>
                <div class="col-entities">Entités</div>
                <div class="col-date">Modifié</div>
                <div class="col-actions"></div>
            </div>

            {% for project in projects %}
                {# --- VUE GRILLE (Card) --- #}
                <div class="grid-only">
                    {{ component('project_card', { project: project }) }}
                </div>

                {# --- VUE LISTE (Row) --- #}
                <div class="project-list-row list-only">
                    <div class="col-main">
                        <div class="project-mini-thumb">
                            {{ ux_icon('lucide:image', {class: 'icon-xs'}) }}
                        </div>
                        <div class="project-info">
                            <span class="project-name">{{ project.title }}</span>
                            <span class="project-sub">{{ project.projectType|capitalize }} - Catégorie</span>
                        </div>
                    </div>

                    <div class="col-status">
                    <span class="badge-status badge--{{ project.status|default('draft') }}">
                        {{ project.status|default('Brouillon') }}
                    </span>
                    </div>

                    <div class="col-progression">
                        <div class="progress-bar-container">
                            <div class="progress-bar-fill" style="width: 45%;"></div>
                        </div>
                    </div>

                    <div class="col-entities">
                        <strong>{{ project.scenarioElements|length + project.characters|length }}</strong>
                    </div>

                    <div class="col-date">{{ project.updatedAt|date('d/m/Y') }}</div>

                    <div class="col-actions">{{ ux_icon('lucide:more-horizontal') }}</div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
