{# templates/workshop/projects/new/step1_mode.html.twig #}
{% trans_default_domain 'workshop' %}


{% extends 'workshop/projects/new/layout.html.twig' %}

{% block title %}{{ 'project_new.step1.title'|trans }}{% endblock %}

{% block new_project_content %}
<div class="project-funnel-container" data-controller="funnel-step1">
    <div class="funnel-header">
        <h1>{{ 'project_new.step1.title'|trans}}</h1>
        <p class="funnel-subtitle">{{ 'project_new.step1.subtitle'|trans }}</p>
    </div>

    <div class="mode-selection">
        {# Mode Simplifié #}
        <div class="mode-card mode-card--simplifie" data-funnel-step1-target="card">
            <div class="mode-card__badge">{{ 'project_new.step1.mode_simplifie.badge'|trans  }}</div>
            <div class="mode-card__icon">
                {{ ux_icon('lucide:zap', {style: 'width: 48px; height: 48px;'}) }}
            </div>
            <h2 class="mode-card__title">{{ 'project_new.step1.title'|trans  }}</h2>

            <ul class="mode-card__features">
                <li>{{ 'project_new.step1.mode_simplifie.desc_1'|trans }}</li>
                <li>{{ 'project_new.step1.mode_simplifie.desc_2'|trans }}</li>
                <li>{{ 'project_new.step1.mode_simplifie.desc_3'|trans }}</li>
            </ul>

            <a href="{{ path('app_project_new_step2', {mode: 'simplifie'}) }}" class="btn btn--cta-yellow">
                {{ 'project_new.step1.mode_simplifie.button'|trans }}
            </a>
        </div>

        {# Mode Custom #}
        <div class="mode-card mode-card--custom" data-funnel-step1-target="card">
            <div class="mode-card__badge mode-card__badge--advanced">{{ 'project_new.step1.mode_custom.badge'|trans }}</div>
            <div class="mode-card__icon">
                {{ ux_icon('lucide:wrench', {style: 'width: 48px; height: 48px;'}) }}
            </div>
            <h2 class="mode-card__title">{{ 'project_new.step1.mode_custom.title'|trans }}</h2>

            <ul class="mode-card__features">
                <li>{{ 'project_new.step1.mode_custom.desc_1'|trans }}</li>
                <li>{{ 'project_new.step1.mode_custom.desc_2'|trans }}</li>
                <li>{{ 'project_new.step1.mode_custom.desc_3'|trans }}</li>
            </ul>

            <a href="{{ path('app_project_new_step2', {mode: 'custom'}) }}" class="btn--cta-yellow">
                {{ 'project_new.step1.mode_custom.button'|trans }}
            </a>
        </div>
    </div>
</div>
{% endblock %}
