{% extends 'workshop/projects/layout.html.twig' %}
{% trans_default_domain 'workshop' %}

{% block title %}{{ 'task.index.title'|trans }} — {{ project.title }}{% endblock %}

{% block project_content %}

{# ── Racine Stimulus ──────────────────────────────────────────────────────── #}
<div class="dashboard-container"
     data-controller="task-list"
     data-task-list-label-deleted-value="{{ 'task.toast.deleted'|trans }}"
     data-task-list-label-undo-value="{{ 'task.toast.undo'|trans }}"
     data-task-list-label-status-value="{{ 'task.toast.status_changed'|trans }}">

    {# ── Header ───────────────────────────────────────────────────────────── #}
    <header class="page-header">
        <div>
            <h1>{{ 'task.index.title'|trans }}</h1>
            <p class="page-subtitle">{{ 'task.index.subtitle'|trans }}</p>
        </div>
        {% if not (readonly ?? false) and allTasks is not empty %}
        <a href="{{ path('app_task_new', {project_slug: project.slug}) }}"
           class="btn-creat"
           data-turbo-frame="modal-frame"
           data-action="click->modal#open">
            {{ ux_icon('lucide:plus', {style: 'width:16px;height:16px'}) }}
            {{ 'task.index.create'|trans }}
        </a>
        {% endif %}
    </header>

    {% if allTasks is empty %}

        {# ── État vide ────────────────────────────────────────────────────── #}
        <div class="page-empty">
            {{ ux_icon('lucide:check-square', {style: 'width:44px;height:44px'}) }}
            <h3>{{ 'task.index.empty.title'|trans }}</h3>
            <p>{{ 'task.index.empty.message'|trans }}</p>
            {% if not (readonly ?? false) %}
            <a href="{{ path('app_task_new', {project_slug: project.slug}) }}"
               class="btn-creat"
               data-turbo-frame="modal-frame"
               data-action="click->modal#open">
                {{ ux_icon('lucide:plus', {style: 'width:15px;height:15px'}) }}
                {{ 'task.index.create_first'|trans }}
            </a>
            {% endif %}
        </div>

    {% else %}

        {# ══════════════════════════════════════════════════════════════════
           RÉCAPITULATIF
           ══════════════════════════════════════════════════════════════════ #}
        {% set progressPct = totalCount > 0 ? ((doneCount / totalCount) * 100)|round : 0 %}

        <div class="tl-summary">

            <div class="tl-summary-card tl-summary-card--overdue">
                <div class="tl-summary-card__icon">
                    {{ ux_icon('lucide:alert-circle', {style: 'width:16px;height:16px'}) }}
                </div>
                <div>
                    <div class="tl-summary-card__val" data-summary="overdue">{{ overdueCount }}</div>
                    <div class="tl-summary-card__label">{{ 'task.summary.overdue'|trans }}</div>
                </div>
            </div>

            <div class="tl-summary-card tl-summary-card--urgent">
                <div class="tl-summary-card__icon">
                    {{ ux_icon('lucide:zap', {style: 'width:16px;height:16px'}) }}
                </div>
                <div>
                    <div class="tl-summary-card__val" data-summary="urgent">{{ urgentCount }}</div>
                    <div class="tl-summary-card__label">{{ 'task.summary.urgent'|trans }}</div>
                </div>
            </div>

            <div class="tl-summary-card tl-summary-card--progress">
                <div class="tl-summary-card__icon">
                    {{ ux_icon('lucide:check-circle', {style: 'width:16px;height:16px'}) }}
                </div>
                <div style="flex:1">
                    <div class="tl-summary-card__val">
                        <span data-summary="done">{{ doneCount }}</span>/<span data-summary="total">{{ totalCount }}</span>
                    </div>
                    <div class="tl-summary-card__label">{{ 'task.summary.progress'|trans }}</div>
                    <div class="tl-progress-bar" style="margin-top:6px;width:100%">
                        <div class="tl-progress-bar__fill" style="width:{{ progressPct }}%"></div>
                    </div>
                </div>
            </div>

            {% if archivedCount > 0 %}
            <a href="{{ path('app_task_filter', {_locale: app.request.locale, project_slug: project.slug, status: 'archived'}) }}"
               class="tl-summary-archived">
                {{ ux_icon('lucide:archive', {style: 'width:13px;height:13px'}) }}
                <span data-summary="archived">{{ archivedCount }}</span>
                archivée{{ archivedCount > 1 ? 's' : '' }}
            </a>
            {% endif %}

        </div>

        {# ══════════════════════════════════════════════════════════════════
           FILTRES
           ══════════════════════════════════════════════════════════════════ #}
        <div class="tl-filters">

            {# Filtre statut #}
            <div class="tl-filters__group">
                <button type="button"
                        class="tl-filter-btn tl-filter-status tl-filter-btn--active"
                        data-action="click->task-list#filterStatus"
                        data-status="">
                    {{ 'task.filter.all'|trans }}
                </button>
                {% for s in ['todo', 'in_progress', 'review', 'done'] %}
                <button type="button"
                        class="tl-filter-btn tl-filter-status"
                        data-action="click->task-list#filterStatus"
                        data-status="{{ s }}">
                    {{ ('task.status.' ~ s)|trans }}
                </button>
                {% endfor %}
            </div>

            <div class="tl-filters__sep"></div>

            {# Filtre priorité #}
            <select class="tl-filter-select"
                    name="priority_filter"
                    aria-label="{{ 'task.filter.all_priorities'|trans }}"
                    data-action="change->task-list#filterPriority">
                <option value="">{{ 'task.filter.all_priorities'|trans }}</option>
                {% for p in ['low', 'normal', 'high', 'urgent'] %}
                <option value="{{ p }}">{{ ('task.priority.' ~ p)|trans }}</option>
                {% endfor %}
            </select>

        </div>

        {# ══════════════════════════════════════════════════════════════════
           LISTE
           ══════════════════════════════════════════════════════════════════ #}

        {# ── Bandeau vue archivées ─────────────────────────────────────── #}
        {% if currentStatus == 'archived' %}
        <div class="tl-archived-banner">
            {{ ux_icon('lucide:archive', {style: 'width:13px;height:13px'}) }}
            Vue archivées — ces tâches ne s'affichent pas dans la vue principale.
            <a href="{{ path('app_task_index', {_locale: app.request.locale, project_slug: project.slug}) }}"
               class="tl-archived-back">
                {{ ux_icon('lucide:arrow-left', {style: 'width:11px;height:11px'}) }}
                Retour
            </a>
        </div>
        {% endif %}

        {# En-tête colonnes #}
        <div class="tl-header">
            <span>{{ 'task.col.name'|trans }}</span>
            <span class="tl-header-desc">{{ 'task.col.description'|trans }}</span>
            <span>{{ 'task.col.status'|trans }}</span>
            <span class="tl-header-priority">{{ 'task.col.priority'|trans }}</span>
            <span>{{ 'task.col.assignee'|trans }}</span>
            <span></span>
        </div>

        <div class="tl-body">
        {% for task in allTasks %}

            {# Données sur la ligne pour le controller JS #}
            <div class="tl-row tl-row--{{ task.status }}"
                 id="task-row-{{ task.id }}"
                 data-task-id="{{ task.id }}"
                 data-task-status="{{ task.status }}"
                 data-task-priority="{{ task.priority }}"
                 data-task-title="{{ task.title|e('html_attr') }}"
                 data-task-due="{{ task.dueDate ? task.dueDate|date('Y-m-d') : '' }}"
                 data-status-url="{{ path('app_task_change_status', {_locale: app.request.locale, project_slug: project.slug, id: task.id}) }}"
                 data-status-csrf="{{ csrf_token('task_status_' ~ task.id) }}"
                 data-priority-url="{{ path('app_task_change_priority', {_locale: app.request.locale, project_slug: project.slug, id: task.id}) }}"
                 data-priority-csrf="{{ csrf_token('task_priority_' ~ task.id) }}"
                 data-delete-url="{{ path('app_task_delete', {_locale: app.request.locale, project_slug: project.slug, id: task.id}) }}"
                 data-delete-csrf="{{ csrf_token('delete' ~ task.id) }}">

                {# ── Nom + chemin narratif ─────────────────────────────── #}
                <div class="tl-cell tl-cell--name">
                    <a href="{{ path('app_task_show', {_locale: app.request.locale, project_slug: project.slug, id: task.id}) }}"
                       class="tl-task-title">
                        {{ task.title }}
                    </a>
                    {% if elementPaths[task.id] is defined %}
                        {% set el = elementPaths[task.id] %}
                        <div class="tl-task-path">
                            {{ ux_icon('lucide:map-pin', {style: 'width:10px;height:10px'}) }}
                            <a href="{{ path('app_manuscript_show', {_locale: app.request.locale, project_slug: project.slug, id: el.id}) }}">
                                {{ el.getFullPath() }}
                            </a>
                        </div>
                    {% endif %}
                </div>

                {# ── Description courte ───────────────────────────────── #}
                <div class="tl-cell tl-cell--desc">
                    {% if task.description %}
                        {{ task.description|striptags|slice(0, 70) }}{% if task.description|length > 70 %}…{% endif %}
                    {% endif %}
                </div>

                {# ── Boutons de statut ────────────────────────────────── #}
                <div class="tl-cell tl-cell--status">

                    <button type="button"
                            class="tl-status-btn {{ task.status == 'todo' ? 'tl-status-btn--active' : '' }}"
                            data-action="click->task-list#changeStatus"
                            data-status="todo"
                            data-tooltip="{{ 'task.status.todo'|trans }}"
                            aria-pressed="{{ task.status == 'todo' ? 'true' : 'false' }}"
                            title="{{ 'task.status.todo'|trans }}">
                        {{ ux_icon('lucide:circle', {style: 'width:13px;height:13px'}) }}
                    </button>

                    <button type="button"
                            class="tl-status-btn {{ task.status == 'in_progress' ? 'tl-status-btn--active' : '' }}"
                            data-action="click->task-list#changeStatus"
                            data-status="in_progress"
                            data-tooltip="{{ 'task.status.in_progress'|trans }}"
                            aria-pressed="{{ task.status == 'in_progress' ? 'true' : 'false' }}"
                            title="{{ 'task.status.in_progress'|trans }}">
                        {{ ux_icon('lucide:loader-circle', {style: 'width:13px;height:13px'}) }}
                    </button>

                    <button type="button"
                            class="tl-status-btn {{ task.status == 'review' ? 'tl-status-btn--active' : '' }}"
                            data-action="click->task-list#changeStatus"
                            data-status="review"
                            data-tooltip="{{ 'task.status.review'|trans }}"
                            aria-pressed="{{ task.status == 'review' ? 'true' : 'false' }}"
                            title="{{ 'task.status.review'|trans }}">
                        {{ ux_icon('lucide:eye', {style: 'width:13px;height:13px'}) }}
                    </button>

                    <button type="button"
                            class="tl-status-btn {{ task.status == 'done' ? 'tl-status-btn--active' : '' }}"
                            data-action="click->task-list#changeStatus"
                            data-status="done"
                            data-tooltip="{{ 'task.status.done'|trans }}"
                            aria-pressed="{{ task.status == 'done' ? 'true' : 'false' }}"
                            title="{{ 'task.status.done'|trans }}">
                        {{ ux_icon('lucide:check-circle', {style: 'width:13px;height:13px'}) }}
                    </button>

                </div>

                {# ── Priorité ─────────────────────────────────────────── #}
                <div class="tl-cell tl-cell--priority">
                    {% if not (readonly ?? false) %}
                    <select class="tl-priority-select tl-priority-select--{{ task.priority }}"
                            name="priority_{{ task.id }}"
                            aria-label="{{ 'task.col.priority'|trans }}"
                            data-action="change->task-list#changePriority"
                            data-current-priority="{{ task.priority }}">
                        {% for p in ['low', 'normal', 'high', 'urgent'] %}
                        <option value="{{ p }}" {{ task.priority == p ? 'selected' : '' }}>
                            {{ ('task.priority.' ~ p)|trans }}
                        </option>
                        {% endfor %}
                    </select>
                    {% else %}
                    <span class="tl-priority tl-priority--{{ task.priority }}">
                        {{ ('task.priority.' ~ task.priority)|trans }}
                    </span>
                    {% endif %}
                </div>

                {# ── Assigné ──────────────────────────────────────────── #}
                <div class="tl-cell tl-cell--assignee">
                    {% if task.assignedTo %}
                        {{ include('_partials/_user_avatar.html.twig', {user: task.assignedTo, size: 'xs'}) }}
                        <span class="tl-assignee-name">{{ task.assignedTo.username }}</span>
                    {% endif %}
                </div>

                {# ── Actions ──────────────────────────────────────────── #}
                <div class="tl-cell tl-cell--actions">
                    {% if not (readonly ?? false) %}
                        {% if currentStatus != 'archived' %}
                        <button type="button"
                                class="tl-btn-icon"
                                data-action="click->task-list#archiveTask"
                                title="Archiver">
                            {{ ux_icon('lucide:archive', {style: 'width:13px;height:13px'}) }}
                        </button>
                        {% endif %}
                        <a href="{{ path('app_task_edit', {_locale: app.request.locale, project_slug: project.slug, id: task.id}) }}"
                           class="tl-btn-icon"
                           title="{{ 'common.edit'|trans }}"
                           data-turbo-frame="modal-frame"
                           data-action="click->modal#open">
                            {{ ux_icon('lucide:pencil', {style: 'width:13px;height:13px'}) }}
                        </a>
                        <button type="button"
                                class="tl-btn-icon tl-btn-icon--danger"
                                data-action="click->task-list#deleteTask"
                                title="{{ 'common.delete'|trans }}">
                            {{ ux_icon('lucide:trash-2', {style: 'width:13px;height:13px'}) }}
                        </button>
                    {% endif %}
                </div>

            </div>

        {% endfor %}
        </div>

    {% endif %}

</div>
{% endblock %}
