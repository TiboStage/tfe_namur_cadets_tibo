{% extends 'workshop/projects/layout.html.twig' %}
{% trans_default_domain 'workshop_interface' %}

{% block title %}{{ 'character.edit.title'|trans }} {{ character.name }} — {{ project.title }}{% endblock %}

{% block project_content %}
    <div class="dashboard-container">

        <header class="page-header">
            <div>
                <a href="{{ path('app_character_show', {project_slug: project.slug, id: character.id}) }}" class="link-back">
                    ← {{ character.name }}
                </a>
                <h1>{{ 'character.edit.title'|trans }}</h1>
            </div>
        </header>

        <div class="form-page-wrapper" style="max-width: 900px;">

            {{ form_start(form, {
                'attr': {
                    'novalidate': 'novalidate',
                    'class': 'project-form',
                    'data-controller': 'validator',
                    'data-validator-error-value': 'form.errors.required_invalid'|trans({}, 'validators'),
                    'data-action': 'submit->validator#validateForm'
                }
            }) }}

            <div class="character-form-grid">

                {# ── Colonne gauche — Identité ─────────────────────────────────── #}
                <div>
                    <div class="form-section-title">{{ 'character.form.section_identity'|trans }}</div>

                    {{ form_row(form.name, {
                        'label': 'character.form.name'|trans
                    }) }}

                    <div class="form-row-two">
                        {{ form_row(form.firstName, {
                            'label': 'character.form.firstname'|trans
                        }) }}
                        {{ form_row(form.lastName, {
                            'label': 'character.form.lastname'|trans
                        }) }}
                    </div>

                    {{ form_row(form.nickname, {
                        'label': 'character.form.nickname'|trans
                    }) }}

                    {{ form_row(form.role, {
                        'label': 'character.form.role'|trans
                    }) }}

                    {{ form_row(form.description, {
                        'label': 'character.form.description'|trans,
                        'attr': {'rows': 3}
                    }) }}
                </div>

                {# ── Colonne droite — Psychologie ──────────────────────────────── #}
                <div>
                    <div class="form-section-title">{{ 'character.form.section_psychology'|trans }}</div>

                    {{ form_row(form.biography, {
                        'label': 'character.form.biography'|trans,
                        'attr': {'rows': 5}
                    }) }}

                    {{ form_row(form.goals, {
                        'label': 'character.form.goals'|trans,
                        'attr': {'rows': 3}
                    }) }}

                    {{ form_row(form.motivations, {
                        'label': 'character.form.motivations'|trans,
                        'attr': {'rows': 3}
                    }) }}

                    {{ form_row(form.characterArc, {
                        'label': 'character.form.arc'|trans,
                        'attr': {'rows': 3}
                    }) }}
                </div>

            </div>

            <div class="form-actions">
                <a href="{{ path('app_character_show', {project_slug: project.slug, id: character.id}) }}" class="btn-export">
                    {{ 'character.edit.cancel'|trans }}
                </a>
                <button type="submit" class="btn-creat">
                    {{ 'character.edit.submit'|trans }}
                </button>
            </div>

            {{ form_end(form) }}

            {# ── DANGER ZONE (suppression) ──────────────────────────────────── #}
            <div class="danger-zone">
                <div class="danger-zone-header">
                    <h3>{{ 'character.edit.danger_zone'|trans }}</h3>
                    <p>{{ 'character.edit.danger_desc'|trans }}</p>
                </div>
                <form method="post" action="{{ path('app_character_delete', {project_slug: project.slug, id: character.id}) }}"
                      onsubmit="return confirm('{{ 'character.edit.delete_confirm'|trans }}');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_character_' ~ character.id) }}">
                    <button type="submit" class="btn-danger">
                        {{ 'character.edit.delete_btn'|trans }}
                    </button>
                </form>
            </div>

        </div>
    </div>
{% endblock %}
