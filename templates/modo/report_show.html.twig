{# templates/modo/report_show.html.twig #}
{% extends 'modo/layout.html.twig' %}

{% block title %}Modo — Signalement #{{ report.id }}{% endblock %}
{% block modo_title %}Signalement #{{ report.id }}{% endblock %}

{% block modo_content %}

    <div class="modo-row-header mb-5">
        <a href="{{ path('modo_report_list', {_locale: app.request.locale}) }}" class="btn-table text-2xs">
            ← Retour à la liste
        </a>
        <span class="mod-badge mod-badge--{{ report.status }}">
            {% if report.status == 'pending' %}En attente
            {% elseif report.status == 'reviewed' %}Examiné
            {% elseif report.status == 'dismissed' %}Rejeté
            {% else %}Traité{% endif %}
        </span>
    </div>

    <div class="modo-report-grid">

        {# ── Détail principal ──────────────────────────────────────────── #}
        <div class="panel-box">
            <div class="panel-header">
                <h3>{{ 'reports.detail.title'|trans({}, 'admin') }}</h3>
                <span class="text-muted text-2xs">{{ report.createdAt|date('d/m/Y à H:i') }}</span>
            </div>

            <div class="modo-report-body">

                {# Type + Cible #}
                <div>
                    <div class="admin-label">Élément signalé</div>
                    {% if report.targetType == 'project' %}
                        <div class="modo-target-row">
                            <span class="tag-reason tag-reason--blue">Projet</span>
                            {% if report.targetProject %}
                                <strong>{{ report.targetProject.title }}</strong>
                                <span class="text-muted">par {{ report.targetProject.createdBy.username }}</span>
                            {% else %}
                                <em class="text-muted">Projet supprimé</em>
                            {% endif %}
                        </div>
                    {% elseif report.targetType == 'comment' %}
                        <div class="mt-2">
                            <span class="tag-reason tag-reason--purple">Commentaire</span>
                            {% if report.targetComment %}
                                <div class="modo-comment-box">
                                    {{ report.targetComment.content }}
                                    <div class="modo-comment-meta">
                                        Par {{ report.targetComment.author.username }}
                                        · {{ report.targetComment.createdAt|date('d/m/Y H:i') }}
                                        · Sur <em>{{ report.targetComment.project.title }}</em>
                                    </div>
                                </div>
                            {% else %}
                                <em class="text-muted ml-2">Commentaire supprimé</em>
                            {% endif %}
                        </div>
                    {% else %}
                        <div class="modo-target-row">
                            <span class="tag-reason tag-reason--orange">Utilisateur</span>
                            {% if report.targetUser %}
                                <strong>{{ report.targetUser.username }}</strong>
                            {% else %}
                                <em class="text-muted">Utilisateur supprimé</em>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>

                {# Raison #}
                <div>
                    <div class="admin-label">Raison</div>
                    <div class="mt-2">
                        <span class="tag-reason">{{ report.reasonLabel }}</span>
                    </div>
                </div>

                {# Description #}
                {% if report.description %}
                <div>
                    <div class="admin-label">Description complémentaire</div>
                    <p class="modo-reason-text">{{ report.description }}</p>
                </div>
                {% endif %}

                {# Signalé par #}
                <div>
                    <div class="admin-label">Signalé par</div>
                    <div class="modo-target-text">
                        {{ report.reporter.username }}
                        <span class="text-muted">· {{ report.reporter.email }}</span>
                    </div>
                </div>

                {# Examiné par #}
                {% if report.reviewedBy %}
                <div>
                    <div class="admin-label">Examiné par</div>
                    <div class="modo-target-text">
                        {{ report.reviewedBy.username }}
                        {% if report.reviewedAt %}
                            <span class="text-muted">le {{ report.reviewedAt|date('d/m/Y à H:i') }}</span>
                        {% endif %}
                    </div>
                </div>
                {% endif %}

            </div>
        </div>

        {# ── Actions ──────────────────────────────────────────────────── #}
        <div class="panel-box">
            <div class="panel-header">
                <h3>{{ 'reports.detail.actions_title'|trans({}, 'admin') }}</h3>
            </div>
            <div class="modo-report-side">

                {% if report.status == 'pending' %}
                    <p class="modo-info-text">
                        Choisissez une action pour traiter ce signalement.
                    </p>
                {% endif %}

                {# Formulaire de changement de statut #}
                <form
                    action="{{ path('modo_report_review', {id: report.id, _locale: app.request.locale}) }}"
                    method="post"
                    class="modo-report-actions"
                >
                    <input type="hidden" name="_token" value="{{ csrf_token('report_review_' ~ report.id) }}">

                    <button type="submit" name="status" value="reviewed" class="btn-admin btn-admin--outline">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Marquer comme examiné
                    </button>

                    <button type="submit" name="status" value="dismissed" class="btn-admin btn-admin--outline">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                        Rejeter (non fondé)
                    </button>

                    <button type="submit" name="status" value="actioned" class="btn-admin btn-admin--danger">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        Action prise
                    </button>
                </form>

            </div>
        </div>

    </div>

{% endblock %}
