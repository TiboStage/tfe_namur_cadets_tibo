{% extends 'workshop/projects/layout.html.twig' %}
{% trans_default_domain 'workshop' %}

{% block title %}{{ 'location.new.title'|trans }} — {{ project.title }}{% endblock %}

{% block project_content %}
<div class="workshop-container">

    {# ── En-tête page (accès direct uniquement) ────────────────────── #}
    <header class="page-header">
        <div>
            <a href="{{ path('app_location_index', {project_slug: project.slug}) }}" class="link-back">
                {{ ux_icon('lucide:arrow-left', {class: 'icon-xs'}) }}
                {{ 'location.new.back'|trans }}
            </a>
            <h1>{{ 'location.new.title'|trans }}</h1>
        </div>
    </header>

    <div class="form-page-wrapper" data-controller="advanced-form">

        {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'project-form'}}) }}

        <div class="form-section">
            {{ form_row(form.name, {'label': 'location.form.name'|trans, 'attr': {'placeholder': 'location.form.name_placeholder'|trans, 'autofocus': true}}) }}
            {{ form_row(form.type, {'label': 'location.form.type'|trans}) }}
        </div>

        <label class="advanced-toggle">
            <input type="checkbox"
                   class="advanced-toggle__checkbox"
                   data-advanced-form-target="checkbox"
                   data-action="change->advanced-form#toggle">
            <span class="advanced-toggle__label">
                {{ ux_icon('lucide:settings-2', {style: 'width:13px;height:13px'}) }}
                {{ 'location.new.advanced'|trans }}
            </span>
        </label>

        <div data-advanced-form-target="panel" hidden>
            <div class="advanced-panel">
                <div class="advanced-panel__section">
                    {{ form_row(form.description, {'label': 'location.form.description'|trans, 'attr': {'placeholder': 'location.form.description_placeholder'|trans, 'rows': 4}}) }}
                </div>
            </div>
        </div>

        <div class="form-actions">
            <a href="{{ path('app_location_index', {project_slug: project.slug}) }}" class="btn-export">
                {{ 'location.new.cancel'|trans }}
            </a>
            <button type="submit" class="btn-creat">{{ 'location.new.submit'|trans }}</button>
        </div>

        {{ form_end(form) }}

    </div>

</div>
{% endblock %}
