<div data-controller="project-sync" data-project-sync-project-id-value="{{ project.id }}">

    {# Barre de contrôle supérieure #}
    <header class="project-header">
        <span data-project-sync-target="indicator">✓ À jour</span>
        <button data-action="project-sync#syncWithServer" class="btn-save">Sauvegarder maintenant</button>
    </header>

    <nav class="sidebar-icons">
        <button data-action="click->project-sync#switchView" data-view="editor">Texte</button>
        <button data-action="click->project-sync#switchView" data-view="characters">Personnages</button>
    </nav>

    <div class="views-container">
        {# VUE ÉDITEUR #}
        <section id="view-editor" data-project-sync-target="view">
            <div contenteditable="true"
                 data-action="input->project-sync#updateData"
                 data-field="content">
                {{ project.content }}
            </div>
        </section>

        {# VUE PERSONNAGES #}
        <section id="view-characters" data-project-sync-target="view" class="hidden">
            {# Liste des personnages éditable en AJAX ici #}
        </section>
    </div>
</div>
