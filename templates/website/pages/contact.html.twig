{% extends 'website/layout.html.twig' %}
{% trans_default_domain 'website' %}

{% block title %}{{ 'meta.contact_title'|trans }}{% endblock %}

{% block content %}
    <main class="container contact-page section-header">
        <div class="contact-grid">

            <div class="contact-info">
                <span class="section-tag">{{ 'contact.info.tag'|trans }}</span>
                <h1 class="main-title">{{ 'contact.info.title'|trans }}<br>
                    <span class="highlight">{{ 'contact.info.title_highlight'|trans }}</span>
                </h1>
                <p class="section-desc">{{ 'contact.info.description'|trans }}</p>

                <div class="info-cards-stack">
                    <div class="info-card">
                        <div class="info-icon"><i class="fa-regular fa-clock"></i></div>
                        <div class="info-content">
                            <h4>{{ 'contact.info.cards.response_time'|trans }}</h4>
                            <p>{{ 'contact.info.cards.response_desc'|trans }}<br>
                                <span>{{ 'contact.info.cards.response_sub'|trans }}</span>
                            </p>
                        </div>
                    </div>
                    <div class="info-card">
                        <div class="info-icon"><i class="fa-solid fa-graduation-cap"></i></div>
                        <div class="info-content">
                            <h4>{{ 'contact.info.cards.academic'|trans }}</h4>
                            <p>{{ 'contact.info.cards.academic_desc'|trans }}<br>
                                {{ 'contact.info.cards.academic_location'|trans }}
                            </p>
                        </div>
                    </div>
                </div>

                <div class="social-links">
                    <a href="#" class="social-box"><i class="fa-brands fa-x-twitter"></i></a>
                    <a href="#" class="social-box"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#" class="social-box"><i class="fa-brands fa-discord"></i></a>
                    <a href="#" class="social-box"><i class="fa-brands fa-linkedin-in"></i></a>
                </div>
            </div>

            <div class="form-wrapper">
                <div class="form-card">
                    <h2>{{ 'contact.form.title'|trans }}</h2>

                    <form action="{{ path('app_contact') }}"
                          method="POST"
                          novalidate
                          data-controller="contact-form">

                        <div class="form-group full">
                            <label for="email">{{ 'contact.form.labels.email'|trans }} <span class="required">*</span></label>
                            <input type="email" id="email" name="email"
                                   placeholder="john.doe@scenart.be"
                                   value="{{ app.request.request.get('email', '') }}"
                                   data-contact-form-target="email"
                                   data-action="blur->contact-form#validateEmail">
                            <span class="error-message" data-contact-form-target="emailError"></span>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="firstname">{{ 'contact.form.labels.firstname'|trans }} <span class="required">*</span></label>
                                <input type="text" id="firstname" name="firstname"
                                       value="{{ app.request.request.get('firstname', '') }}"
                                       data-contact-form-target="firstname"
                                       data-action="blur->contact-form#validateRequired">
                                <span class="error-message" data-contact-form-target="firstnameError"></span>
                            </div>
                            <div class="form-group">
                                <label for="lastname">{{ 'contact.form.labels.lastname'|trans }} <span class="required">*</span></label>
                                <input type="text" id="lastname" name="lastname"
                                       value="{{ app.request.request.get('lastname', '') }}"
                                       data-contact-form-target="lastname"
                                       data-action="blur->contact-form#validateRequired">
                                <span class="error-message" data-contact-form-target="lastnameError"></span>
                            </div>
                        </div>

                        <div class="form-group full">
                            <label for="subject">{{ 'contact.form.labels.subject'|trans }} <span class="required">*</span></label>
                            <select id="subject" name="subject"
                                    data-contact-form-target="subject"
                                    data-action="change->contact-form#validateRequired">
                                <option value="">{{ 'contact.form.placeholders.subject'|trans }}</option>
                                <option value="support" {{ app.request.request.get('subject') == 'support' ? 'selected' : '' }}>
                                    {{ 'contact.form.subjects.support'|trans }}
                                </option>
                                <option value="billing" {{ app.request.request.get('subject') == 'billing' ? 'selected' : '' }}>
                                    {{ 'contact.form.subjects.billing'|trans }}
                                </option>
                                <option value="partnership" {{ app.request.request.get('subject') == 'partnership' ? 'selected' : '' }}>
                                    {{ 'contact.form.subjects.partnership'|trans }}
                                </option>
                            </select>
                            <span class="error-message" data-contact-form-target="subjectError"></span>
                        </div>

                        <div class="form-group full">
                            <label for="message">{{ 'contact.form.labels.message'|trans }} <span class="required">*</span></label>
                            <textarea id="message" name="message" rows="5"
                                      placeholder="{{ 'contact.form.placeholders.message'|trans }}"
                                      data-contact-form-target="message"
                                      data-action="blur->contact-form#validateMessage">{{ app.request.request.get('message', '') }}</textarea>
                            <span class="error-message" data-contact-form-target="messageError"></span>
                        </div>

                        <div class="form-checkbox">
                            <input type="checkbox" id="privacy" name="privacy"
                                   data-contact-form-target="privacy"
                                   data-action="change->contact-form#validatePrivacy">
                            <label for="privacy">
                                {{ 'contact.form.privacy'|trans }}
                                <a href="#">{{ 'contact.form.privacy_link'|trans }}</a>.
                            </label>
                            <span class="error-message" data-contact-form-target="privacyError"></span>
                        </div>

                        <button type="submit" class="btn-primary-pricing">
                            {{ 'contact.form.submit'|trans }}
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </main>
{% endblock %}
