{% extends 'workshop/layout.html.twig' %}

{% block content %}
    <div class="workshop-wrapper">
        {# --- BARRE LATÉRALE GAUCHE : NAVIGATION NARRATIVE --- #}
        <aside class="workshop-sidebar-left">
            <div class="sidebar-header">
                <h3>{{ project.title }}</h3>
                <small>{{ project.projectType|upper }}</small>
            </div>

            <nav class="tree-nav">
                <div class="tree-group">
                    <span class="tree-label">MANUSCRIT</span>
                    <a href="{{ path('app_scenario_new', {slug: project.slug, depth: 1}) }}" class="btn-add-mini">+</a>
                </div>

                <div class="scenario-tree">
                    {% for root in rootElements %}
                        {{ _self.renderTree(root, project) }}
                    {% else %}
                        <p class="empty-msg">Aucun élément narratif.</p>
                    {% endfor %}
                </div>

                <div class="tree-group mt-4">
                    <span class="tree-label">ENCYCLOPÉDIE</span>
                </div>
                <a href="{{ path('app_character_index', {slug: project.slug}) }}" class="tree-item">
                    <span class="icon">👤</span> Personnages
                </a>
                <a href="{{ path('app_location_index', {slug: project.slug}) }}" class="tree-item">
                    <span class="icon">📍</span> Lieux & Atlas
                </a>
            </nav>
        </aside>

        {# --- ZONE CENTRALE : VUE D'ENSEMBLE (TABLEAU DE BORD) --- #}
        <main class="workshop-main-content">
            <header class="content-header">
                <h1>Tableau de bord narratif</h1>
                <div class="header-actions">
                    <a href="{{ path('app_project_show', {slug: project.slug}) }}" class="btn-secondary">Paramètres Projet</a>
                </div>
            </header>

            <div class="dashboard-grid">
                {# Résumé des scènes #}
                <section class="dashboard-card">
                    <h4>Dernières modifications</h4>
                    <div class="recent-list">
                        {# Ici tu pourras boucler sur les derniers ScenarioElements modifiés #}
                        <p class="text-muted">Sélectionnez un élément dans la liste à gauche pour commencer l'écriture.</p>
                    </div>
                </section>

                {# Statistiques ou Notes rapides #}
                <section class="dashboard-card card-yellow">
                    <h4>Notes de recherche</h4>
                    <p>N'oubliez pas de lier les personnages aux scènes pour l'Inspecteur.</p>
                </section>
            </div>
        </main>
    </div>

    {# --- MACRO POUR L'ARBORESCENCE --- #}
    {% macro renderTree(element, project) %}
        <div class="tree-node depth-{{ element.depth }}">
            <div class="tree-row">
            <span class="node-icon">
                {% if element.depth == 1 %}📁{% elseif element.depth == 2 %}📂{% else %}📄{% endif %}
            </span>
                <a href="#" class="node-link">
                    {{ element.title }}
                </a>
                <div class="node-ops">
                    {% if element.depth < 3 %}
                        <a href="{{ path('app_scenario_new', {slug: project.slug, depth: element.depth + 1, parent_id: element.id}) }}">+</a>
                    {% endif %}
                </div>
            </div>

            {% if element.children is not empty %}
                <div class="node-children">
                    {% for child in element.children %}
                        {{ _self.renderTree(child, project) }}
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    {% endmacro %}
{% endblock %}
