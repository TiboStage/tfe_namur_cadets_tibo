
{% extends 'base.html.twig' %}
{% trans_default_domain 'workshop' %}

{% block body %}
<div class="fn-wrapper">

    {# ── Topbar ────────────────────────────────────────────────────── #}
    <header class="fn-topbar">
        <a href="{{ path('app_workshop_dashboard', {_locale: app.request.locale}) }}" class="fn-topbar__logo">
            <img src="{{ asset('images/favicons/favicon.png') }}" alt="ScénArt" width="26" height="26">
            <span>ScénArt</span>
        </a>

        {# Breadcrumb #}
        <nav class="fn-steps" aria-label="{{ 'funnel.layout.nav_label'|trans }}">
            {% set current = step ?? 1 %}

            <div class="fn-step {{ current == 1 ? 'fn-step--active' : (current > 1 ? 'fn-step--done' : '') }}">
                <span class="fn-step__num">01</span>
                <span class="fn-step__lbl">{{ 'funnel.layout.step_type'|trans }}</span>
            </div>

            <span class="fn-step__sep" aria-hidden="true"></span>

            <div class="fn-step {{ current == 2 ? 'fn-step--active' : (current > 2 ? 'fn-step--done' : '') }}">
                <span class="fn-step__num">02</span>
                <span class="fn-step__lbl">{{ 'funnel.layout.step_infos'|trans }}</span>
            </div>

            <span class="fn-step__sep" aria-hidden="true"></span>

            <div class="fn-step {{ current == 3 ? 'fn-step--active' : '' }}">
                <span class="fn-step__num">03</span>
                <span class="fn-step__lbl">{{ 'funnel.layout.step_structure'|trans }}</span>
            </div>
        </nav>

        <a href="{{ path('app_workshop_dashboard', {_locale: app.request.locale}) }}" class="fn-topbar__cancel">
            {{ 'funnel.layout.cancel'|trans }}
        </a>
    </header>

    {# ── Contenu de l'étape ────────────────────────────────────────── #}
    <main class="fn-main">
        {% block new_project_content %}{% endblock %}
    </main>

</div>
{% endblock %}
