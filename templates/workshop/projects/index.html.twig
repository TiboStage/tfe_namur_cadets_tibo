{% extends 'workshop/layout.html.twig' %}

{% block content %}
    <div class="projects-page">
        {# Header #}
        <div class="page-header">
            <div>
                <h1>Mes projets</h1>
                <p class="text-muted">{{ projects|length }} projet(s) au total</p>
            </div>
            <a href="{{ path('app_project_new') }}" class="btn btn--cta-yellow">
                {{ ux_icon('lucide:plus', {class: 'icon-xs'}) }} Nouveau projet
            </a>
        </div>

        {# Liste des projets #}
        {% if projects is not empty %}
            <div class="projects-grid">
                {% for project in projects %}
                    <article class="project-card">
                        <div class="project-card-header">
                            <div class="project-icon">{{ project.title|first|upper }}</div>
                            <div class="project-meta">
                                <h3>
                                    <a href="{{ path('app_project_show', {slug: project.slug}) }}">
                                        {{ project.title }}
                                    </a>
                                </h3>
                                <p class="text-muted small">
                                    {{ project.projectType|upper }} • {{ project.updatedAt|date('d/m/Y') }}
                                </p>
                            </div>
                        </div>

                        <div class="project-card-body">
                            {% if project.description %}
                                <p>{{ project.description|slice(0, 120) }}{% if project.description|length > 120 %}...{% endif %}</p>
                            {% else %}
                                <p class="text-muted">Aucune description</p>
                            {% endif %}
                        </div>

                        <div class="project-card-footer">
                            <a href="{{ path('app_project_show', {slug: project.slug}) }}" class="btn btn--sm btn--primary">
                                Ouvrir
                            </a>
                            <a href="{{ path('app_project_edit', {slug: project.slug}) }}" class="btn btn--sm btn--ghost">
                                {{ ux_icon('lucide:settings', {class: 'icon-xs'}) }}
                            </a>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <div class="empty-state">
                <p class="text-muted">Vous n'avez encore créé aucun projet.</p>
                <a href="{{ path('app_project_new') }}" class="btn btn--primary">Créer votre premier projet</a>
            </div>
        {% endif %}
    </div>
{% endblock %}
