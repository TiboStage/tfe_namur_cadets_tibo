{% extends 'workshop/projects/layout.html.twig' %}
{% trans_default_domain 'workshop_interface' %}

{% block title %}{{ 'character.new.title'|trans }} — {{ project.title }}{% endblock %}

{% block project_content %}
    <div class="dashboard-container">

        <header class="page-header">
            <div>
                <a href="{{ path('app_character_index', {project_slug: project.slug}) }}" class="link-back">
                    {{ 'character.new.back'|trans }}
                </a>
                <h1>{{ 'character.new.title'|trans }}</h1>
            </div>
        </header>

        <div class="form-page-wrapper" >

            {{ form_start(form, {
                'attr': {
                    'novalidate': 'novalidate',
                    'class': 'project-form',
                    'data-controller': 'validator',
                    'data-validator-error-value': 'form.errors.required_invalid'|trans({}, 'validators'),
                    'data-action': 'submit->validator#validateForm'
                }
            }) }}

            <div class="character-form-grid">

                {# ── Colonne gauche — Identité ─────────────────────────────────── #}
                <div>
                    <div class="form-section-title">{{ 'character.form.section_identity'|trans }}</div>

                    {# AVANT: forms.field() → APRÈS: form_row() #}
                    {{ form_row(form.name, {
                        'label': 'character.form.name'|trans,
                        'attr': {
                            'placeholder': 'character.form.name_placeholder'|trans
                        }
                    }) }}

                    <div class="form-row-two">
                        {{ form_row(form.firstName, {
                            'label': 'character.form.firstname'|trans,
                            'attr': {
                                'placeholder': 'character.form.firstname_placeholder'|trans
                            }
                        }) }}
                        {{ form_row(form.lastName, {
                            'label': 'character.form.lastname'|trans,
                            'attr': {
                                'placeholder': 'character.form.lastname_placeholder'|trans
                            }
                        }) }}
                    </div>

                    {{ form_row(form.nickname, {
                        'label': 'character.form.nickname'|trans,
                        'attr': {
                            'placeholder': 'character.form.nickname_placeholder'|trans
                        }
                    }) }}

                    {{ form_row(form.role, {
                        'label': 'character.form.role'|trans
                    }) }}

                    {{ form_row(form.description, {
                        'label': 'character.form.description'|trans,
                        'attr': {
                            'placeholder': 'character.form.description_placeholder'|trans,
                            'rows': 3
                        }
                    }) }}
                </div>

                {# ── Colonne droite — Psychologie ──────────────────────────────── #}
                <div>
                    <div class="form-section-title">{{ 'character.form.section_psychology'|trans }}</div>

                    {{ form_row(form.biography, {
                        'label': 'character.form.biography'|trans,
                        'attr': {
                            'placeholder': 'character.form.biography_placeholder'|trans,
                            'rows': 5
                        }
                    }) }}

                    {{ form_row(form.goals, {
                        'label': 'character.form.goals'|trans,
                        'attr': {
                            'placeholder': 'character.form.goals_placeholder'|trans,
                            'rows': 3
                        }
                    }) }}

                    {{ form_row(form.motivations, {
                        'label': 'character.form.motivations'|trans,
                        'attr': {
                            'placeholder': 'character.form.motivations_placeholder'|trans,
                            'rows': 3
                        }
                    }) }}

                    {{ form_row(form.characterArc, {
                        'label': 'character.form.arc'|trans,
                        'attr': {
                            'placeholder': 'character.form.arc_placeholder'|trans,
                            'rows': 3
                        }
                    }) }}
                </div>

            </div>

            <div class="form-actions">
                <a href="{{ path('app_character_index', {project_slug: project.slug}) }}" class="btn-export">
                    {{ 'character.new.cancel'|trans }}
                </a>
                <button type="submit" class="btn-creat">
                    {{ 'character.new.submit'|trans }}
                </button>
            </div>

            {{ form_end(form) }}

        </div>
    </div>
{% endblock %}
