<!DOCTYPE html>
<html lang="{{ locale|default('fr') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 — {{ 'error_404.title'|trans({}, 'errors', locale) }} · Scénart</title>
    {{ importmap('app') }}
</head>
<body>
<div class="error-page">
    <div class="error-content">

        <a href="/" class="error-logo">SCÉN<span class="highlight">ART</span></a>

        <div class="error-code">404</div>
        <h1 class="error-title">{{ 'error_404.title'|trans({}, 'errors', locale|default('fr')) }}</h1>
        <p class="error-desc">{{ 'error_404.desc'|trans({}, 'errors', locale|default('fr')) }}</p>
        <p>Locale request: {{ app.request.locale }}</p>
        <p>Locale variable: {{ locale }}</p>
        <div class="error-actions">
            <a href="javascript:history.back()" class="btn-outline">
                {{ 'error_404.btn_back'|trans({}, 'errors', locale|default('fr')) }}
            </a>
            <a href="/{{ locale|default('fr') }}" class="btn-primary">
                {{ 'error_404.btn_home'|trans({}, 'errors', locale|default('fr')) }}
            </a>
        </div>

    </div>
</div>
</body>
</html>
