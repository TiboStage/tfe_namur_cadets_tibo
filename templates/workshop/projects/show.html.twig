{% extends 'workshop/projects/layout.html.twig' %}

{% block project_content %}
    <div class="project-dashboard">

        {# ── Header projet ────────────────────────────────────── #}
        <header class="dashboard-header">
            <div class="header-content">
                <div class="project-meta">
                    <span class="project-icon-lg">{{ project.title|first|upper }}</span>
                    <div>
                        <h1 class="project-title">{{ project.title }}</h1>
                        <span class="project-type">{{ project.projectType }}</span>
                    </div>
                </div>
            </div>
            <p class="project-description">
                {% if project.description %}
                    {{ project.description }}
                {% else %}
                    Aucune description pour ce projet.
                {% endif %}
            </p>
        </header>

        {# ── Grille statistiques ──────────────────────────────── #}
        <section class="stats-section">
            <div class="stat-card">
                <div class="stat-icon">
                    {{ ux_icon('lucide:file-text') }}
                </div>
                <div class="stat-content">
                    <span class="stat-value">{{ stats.scenes_count }}</span>
                    <span class="stat-label">Scènes</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    {{ ux_icon('lucide:users') }}
                </div>
                <div class="stat-content">
                    <span class="stat-value">{{ stats.characters_count }}</span>
                    <span class="stat-label">Personnages</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    {{ ux_icon('lucide:map-pin') }}
                </div>
                <div class="stat-content">
                    <span class="stat-value">{{ stats.locations_count }}</span>
                    <span class="stat-label">Lieux</span>
                </div>
            </div>

            <div class="stat-card stat-highlight">
                <div class="stat-icon">
                    {{ ux_icon('lucide:clock') }}
                </div>
                <div class="stat-content">
                <span class="stat-value">
                    {{ stats.last_update|date('d/m/Y') }}
                </span>
                    <span class="stat-label">Dernière modification</span>
                </div>
            </div>
        </section>

        {# ── Contenu principal (2 colonnes) ───────────────────── #}
        <div class="dashboard-grid">

            {# Colonne gauche #}
            <div class="grid-main">

                {# Activité récente #}
                <section class="dashboard-card">
                    <h2 class="card-title">
                        {{ ux_icon('lucide:activity') }}
                        Activité récente
                    </h2>

                    {% if recentUpdates is not empty %}
                        <div class="activity-list">
                            {% for item in recentUpdates %}
                                <a href="{{ path('app_manuscript_show', {project_slug: project.slug, id: item.id}) }}"
                                   class="activity-item">
                                    <div class="activity-icon">
                                        {{ ux_icon('lucide:file-text') }}
                                    </div>
                                    <div class="activity-content">
                                        <span class="activity-title">{{ item.title }}</span>
                                        <span class="activity-time">{{ item.updatedAt|date('d/m/Y à H:i') }}</span>
                                    </div>
                                    <div class="activity-arrow">
                                        {{ ux_icon('lucide:chevron-right') }}
                                    </div>
                                </a>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="empty-state">
                            {{ ux_icon('lucide:inbox') }}
                            <p>Aucune activité récente</p>
                            <span>Commencez à écrire pour voir vos modifications ici</span>
                        </div>
                    {% endif %}
                </section>

            </div>

            {# Colonne droite #}
            <div class="grid-sidebar">

                {# Accès rapides #}
                <section class="dashboard-card card-accent">
                    <h2 class="card-title">
                        {{ ux_icon('lucide:zap') }}
                        Accès rapides
                    </h2>

                    <div class="quick-actions">
                        <a href="{{ path('app_manuscript_new', {project_slug: project.slug, depth: 1}) }}"
                           class="quick-action-btn">
                            {{ ux_icon('lucide:plus') }}
                            <span>Créer une scène</span>
                        </a>

                        <a href="{{ path('app_character_new', {project_slug: project.slug}) }}"
                           class="quick-action-btn">
                            {{ ux_icon('lucide:user-plus') }}
                            <span>Nouveau personnage</span>
                        </a>

                        <a href="{{ path('app_location_new', {project_slug: project.slug}) }}"
                           class="quick-action-btn">
                            {{ ux_icon('lucide:map-pin-plus') }}
                            <span>Nouveau lieu</span>
                        </a>
                    </div>
                </section>

                {# Informations projet #}
                <section class="dashboard-card">
                    <h2 class="card-title">
                        {{ ux_icon('lucide:info') }}
                        Informations
                    </h2>

                    <div class="project-infos">
                        <div class="info-item">
                            <span class="info-label">Type de projet</span>
                            <span class="info-value">{{ project.projectType }}</span>
                        </div>

                        <div class="info-item">
                            <span class="info-label">Créé le</span>
                            <span class="info-value">{{ project.createdAt|date('d/m/Y') }}</span>
                        </div>

                        <div class="info-item">
                            <span class="info-label">Statut</span>
                            <span class="info-badge info-badge-draft">Brouillon</span>
                        </div>
                    </div>

                    <a href="{{ path('app_project_edit', {slug: project.slug}) }}"
                       class="btn-settings">
                        {{ ux_icon('lucide:settings') }}
                        Paramètres du projet
                    </a>
                </section>

            </div>

        </div>

    </div>
{% endblock %}
