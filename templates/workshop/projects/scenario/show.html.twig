{% extends 'workshop/projects/scenario/layout.html.twig' %}
{% trans_default_domain 'workshop' %}

{% block title %}{{ element.title }} — {{ project.title }}{% endblock %}

{% block editor_shell %}
{% if element.isLeaf() %}
{% set _editorI18n = {
    'type_action':        'manuscript.editor.type.action'|trans,
    'type_scene':         'manuscript.editor.type.scene'|trans,
    'type_character':     'manuscript.editor.type.character'|trans,
    'type_dialogue':      'manuscript.editor.type.dialogue'|trans,
    'type_parenthetical': 'manuscript.editor.type.parenthetical'|trans,
    'type_transition':    'manuscript.editor.type.transition'|trans,
    'ph_action':          'manuscript.editor.ph.action'|trans,
    'ph_scene':           'manuscript.editor.ph.scene'|trans,
    'ph_character':       'manuscript.editor.ph.character'|trans,
    'ph_dialogue':        'manuscript.editor.ph.dialogue'|trans,
    'ph_parenthetical':   'manuscript.editor.ph.parenthetical'|trans,
    'ph_transition':      'manuscript.editor.ph.transition'|trans,
    'mention_char':       'manuscript.editor.mention.char'|trans,
    'mention_loc':        'manuscript.editor.mention.loc'|trans,
    'mention_hint':       'manuscript.editor.mention.hint'|trans,
    'detect_hint':        'manuscript.editor.detect.hint'|trans,
    'mode_reading':       'manuscript.editor.mode.reading'|trans,
    'mode_writing':       'manuscript.editor.mode.writing'|trans,
    'save_dirty':         'manuscript.editor.save.dirty'|trans,
    'save_saving':        'manuscript.editor.save.saving'|trans,
    'save_saved':         'manuscript.editor.save.saved'|trans,
    'save_error':         'manuscript.editor.save.error'|trans,
    'save_at':            'manuscript.editor.save.at'|trans,
    'word_one':           'manuscript.editor.stats.word_one'|trans,
    'word_other':         'manuscript.editor.stats.word_other'|trans,
    'char_one':           'manuscript.editor.stats.char_one'|trans,
    'char_other':         'manuscript.editor.stats.char_other'|trans,
    'note_aria':          'manuscript.editor.note.aria'|trans,
} %}
{% endif %}
<div class="editor-shell right-collapsed {% if not element.isLeaf() %}editor-shell--folder{% endif %}"
     {% if element.isLeaf() %}
         data-controller="fountain-editor"
         data-fountain-editor-save-url-value="{{ path('app_manuscript_save', {project_slug: project.slug, id: element.id}) }}"
         data-fountain-editor-element-id-value="{{ element.id }}"
         data-fountain-editor-element-title-value="{{ element.title }}"
         data-fountain-editor-content-value="{{ element.content|json_encode|e('html_attr') }}"
         data-fountain-editor-characters-value="{{ project.characters|map(c => {'id': c.id, 'name': ((c.firstName ~ ' ' ~ c.lastName)|trim) ?: c.name})|json_encode|e('html_attr') }}"
         data-fountain-editor-locations-value="{{ project.locations|map(l => {'id': l.id, 'name': l.name})|json_encode|e('html_attr') }}"
         data-fountain-editor-note-new-url-value="{{ path('app_note_new', {project_slug: project.slug, element_id: element.id}) }}"
         data-fountain-editor-words-per-page-value="{{ project.settings.ms_words_per_page ?? 170 }}"
         data-fountain-editor-reading-wpm-value="{{ project.settings.ms_reading_wpm ?? 200 }}"
         data-fountain-editor-screen-time-per-page-value="{{ project.settings.ms_screen_time_per_page ?? 60 }}"
         data-fountain-editor-i18n-value="{{ _editorI18n|json_encode|e('html_attr') }}"
     {% endif %}>

    {# ══════════════════════════════════════════════════════════
       ZONE CENTRALE
       ══════════════════════════════════════════════════════════ #}
    <main class="editor-main">

        {# ── Topbar ────────────────────────────────────────── #}
        <header class="editor-topbar">
            <div class="editor-topbar-left">

                {# Fil d'Ariane (cliquable) #}
                <nav class="editor-breadcrumb">
                    <a href="{{ path('app_manuscript_index', {project_slug: project.slug}) }}"
                       class="breadcrumb-parent breadcrumb-home" title="Manuscrit">
                        {{ ux_icon('lucide:book-open', {class: 'icon-xs'}) }}
                    </a>
                    {% for ancestor in element.getAncestors() %}
                        <span class="breadcrumb-sep">/</span>
                        <a href="{{ path('app_manuscript_show', {project_slug: project.slug, id: ancestor.id}) }}"
                           class="breadcrumb-parent">{{ ancestor.title }}</a>
                    {% endfor %}
                    <span class="breadcrumb-sep">/</span>
                    <span class="breadcrumb-current">{{ element.title }}</span>
                </nav>

                <span class="element-type-pill">{{ element.elementType|upper }}</span>

                {% if element.isLeaf() %}
                    <span class="element-leaf-badge">{{ 'manuscript.show.leaf_badge'|trans }}</span>
                {% else %}
                    <span class="element-folder-badge">
                        {{ ux_icon('lucide:folder', {class: 'icon-xs'}) }}
                        <span>{{ 'manuscript.show.folder_badge'|trans }}</span>
                    </span>
                {% endif %}

            </div>

            <div class="editor-topbar-right">

                {% if element.isLeaf() %}
                    {# Export Fountain #}
                    <button class="topbar-btn" type="button"
                            data-action="fountain-editor#exportFountain"
                            title="Télécharger en format Fountain (.fountain)">
                        {{ ux_icon('lucide:download', {class: 'icon-xs'}) }}
                        <span class="topbar-label-sm">Fountain</span>
                    </button>

                    {# Export PDF #}
                    <button class="topbar-btn" type="button"
                            data-action="fountain-editor#exportPDF"
                            title="Imprimer / Exporter en PDF">
                        {{ ux_icon('lucide:file-text', {class: 'icon-xs'}) }}
                        <span class="topbar-label-sm">PDF</span>
                    </button>

                    <span class="topbar-sep"></span>

                    {# Mode lecture #}
                    <button class="topbar-btn" type="button" id="btn-reading-mode"
                            data-action="fountain-editor#toggleReading">
                        {{ ux_icon('lucide:book-open', {class: 'icon-xs'}) }}
                        <span id="reading-mode-label">{{ 'manuscript.show.reading_btn'|trans }}</span>
                    </button>

                    {# Indicateur sauvegarde #}
                    <span class="save-indicator save-indicator--saved"
                          data-fountain-editor-target="saveIndicator">
                        {{ 'manuscript.show.save_indicator'|trans }}
                    </span>

                    {# Bouton Sauvegarder #}
                    <button class="topbar-btn topbar-btn-primary" type="button"
                            data-action="click->fountain-editor#saveManual"
                            data-fountain-editor-target="saveButton">
                        {{ ux_icon('lucide:save', {class: 'icon-xs'}) }}
                        {{ 'manuscript.show.save_btn'|trans }}
                    </button>
                {% endif %}

                {# Toggle inspecteur droit #}
                <button class="sidebar-toggle sidebar-toggle--active" type="button" title="Inspecteur"
                        onclick="this.closest('.editor-shell').classList.toggle('right-collapsed'); this.classList.toggle('sidebar-toggle--active');">
                    {{ ux_icon('lucide:panel-right', {class: 'icon-sm'}) }}
                </button>

            </div>
        </header>

        {# ══════════════════════════════════════════════════════
           VUE DOSSIER (éléments non-feuilles)
           ══════════════════════════════════════════════════════ #}
        {% if not element.isLeaf() %}
            <div class="folder-view">

                <div class="folder-header">
                    <div class="folder-icon-large">
                        {{ ux_icon('lucide:folder-open', {style: 'width:40px;height:40px;'}) }}
                    </div>
                    <div>
                        <h1 class="folder-title">{{ element.title }}</h1>
                        <p class="folder-meta">
                            {{ element.elementType|upper }}
                            {% if element.getAncestors()|length > 0 %}
                                &nbsp;·&nbsp; {{ element.getFullPath() }}
                            {% endif %}
                        </p>
                    </div>
                    {% set maxDepth = maxDepth %}
                    {% if element.depth < maxDepth %}
                        <a href="{{ path('app_manuscript_new', {project_slug: project.slug, depth: element.depth + 1, parent_id: element.id}) }}"
                           class="topbar-btn topbar-btn-primary">
                            {{ ux_icon('lucide:plus', {class: 'icon-xs'}) }}
                            {{ 'manuscript.show.add_child'|trans }}
                        </a>
                    {% endif %}
                </div>

                {% if element.summary %}
                    <p class="folder-summary">{{ element.summary }}</p>
                {% endif %}

                {% if element.children is not empty %}
                    <div class="folder-children-grid">
                        {% for child in element.children %}
                            <a href="{{ path('app_manuscript_show', {project_slug: project.slug, id: child.id}) }}"
                               class="folder-child-card {% if child.isLeaf() %}folder-child-card--leaf{% endif %}">
                                <div class="folder-child-icon">
                                    {% if child.isLeaf() %}
                                        {{ ux_icon('lucide:file-text', {class: 'icon-sm'}) }}
                                    {% else %}
                                        {{ ux_icon('lucide:folder', {class: 'icon-sm'}) }}
                                    {% endif %}
                                </div>
                                <div class="folder-child-info">
                                    <span class="folder-child-type">{{ child.elementType|upper }}</span>
                                    <span class="folder-child-title">{{ child.title }}</span>
                                    {% if child.summary %}
                                        <span class="folder-child-summary">{{ child.summary|slice(0, 80) }}…</span>
                                    {% endif %}
                                </div>
                                {% if child.isLeaf() %}
                                    <span class="folder-child-badge">{{ 'manuscript.show.leaf_badge'|trans }}</span>
                                {% else %}
                                    <span class="folder-child-count">{{ child.children|length }} {{ 'manuscript.show.child_count'|trans({'%count%': child.children|length}) }}</span>
                                {% endif %}
                            </a>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="folder-empty-children">
                        <p>{{ 'manuscript.show.empty_folder'|trans }}</p>
                        {% set maxDepth = maxDepth %}
                        {% if element.depth < maxDepth %}
                            <a href="{{ path('app_manuscript_new', {project_slug: project.slug, depth: element.depth + 1, parent_id: element.id}) }}"
                               class="topbar-btn">
                                {{ ux_icon('lucide:plus', {class: 'icon-xs'}) }}
                                {{ 'manuscript.show.create_first'|trans }}
                            </a>
                        {% endif %}
                    </div>
                {% endif %}

            </div>

        {# ══════════════════════════════════════════════════════
           VUE ÉDITEUR (scènes / feuilles)
           ══════════════════════════════════════════════════════ #}
        {% else %}

            {# ── Toolbar types de blocs ─────────────────────────────────────── #}
            <div class="editor-toolbar">
                <div class="editor-toolbar-group">
                    <button class="editor-toolbar-btn editor-toolbar-btn--scene" type="button"
                            title="Décor intérieur (INT.)"
                            data-action="fountain-editor#setBlockTypeTool"
                            data-fountain-editor-type-param="SCENE"
                            data-fountain-editor-prefix-param="INT. ">INT.</button>
                    <button class="editor-toolbar-btn editor-toolbar-btn--scene" type="button"
                            title="Décor extérieur (EXT.)"
                            data-action="fountain-editor#setBlockTypeTool"
                            data-fountain-editor-type-param="SCENE"
                            data-fountain-editor-prefix-param="EXT. ">EXT.</button>
                </div>
                <div class="editor-toolbar-sep"></div>
                <div class="editor-toolbar-group">
                    <button class="editor-toolbar-btn" type="button"
                            title="Bloc Action"
                            data-action="fountain-editor#setBlockTypeTool"
                            data-fountain-editor-type-param="ACTION">Action</button>
                    <button class="editor-toolbar-btn" type="button"
                            title="Nom de personnage"
                            data-action="fountain-editor#setBlockTypeTool"
                            data-fountain-editor-type-param="CHARACTER">Personnage</button>
                    <button class="editor-toolbar-btn" type="button"
                            title="Réplique / dialogue"
                            data-action="fountain-editor#setBlockTypeTool"
                            data-fountain-editor-type-param="DIALOGUE">Dialogue</button>
                    <button class="editor-toolbar-btn" type="button"
                            title="Didascalie / parenthétique"
                            data-action="fountain-editor#setBlockTypeTool"
                            data-fountain-editor-type-param="PARENTHETICAL">Didascalie</button>
                    <button class="editor-toolbar-btn" type="button"
                            title="Transition (COUPE SUR…)"
                            data-action="fountain-editor#setBlockTypeTool"
                            data-fountain-editor-type-param="TRANSITION">Transition</button>
                </div>
                <span class="editor-toolbar-hint">Tab = cycle · Shift+Tab = inverse</span>
            </div>

            <div class="editor-paper-wrapper">
                {# Mode lecture (caché par défaut) #}
                <div class="fountain-preview hidden"
                     data-fountain-editor-target="preview"></div>

                {# Mode écriture — container des pages (JS crée les .editor-page ici) #}
                <div class="fountain-stage"
                     data-fountain-editor-target="stage"></div>
            </div>

            <footer class="editor-statusbar">
                <span class="editor-type-pill"
                      data-fountain-editor-target="typePill"
                      data-type="ACTION">{{ 'manuscript.editor.type.action'|trans }}</span>
                <span class="statusbar-sep">·</span>
                <span data-fountain-editor-target="wordCount">0 {{ 'manuscript.editor.stats.word_one'|trans }}</span>
                <span class="statusbar-sep">·</span>
                <span data-fountain-editor-target="charCount">0 {{ 'manuscript.editor.stats.char_one'|trans }}</span>
                <span class="statusbar-sep">·</span>
                <span data-fountain-editor-target="lastSaved"></span>
                <span class="statusbar-hint">{{ 'manuscript.show.statusbar.hint'|trans }}</span>
            </footer>

        {% endif %}
    </main>

    {# ══════════════════════════════════════════════════════════
       SIDEBAR DROITE — Inspecteur
       ══════════════════════════════════════════════════════════ #}
    <aside class="editor-sidebar-right" id="editor-right-panel">

        <div class="esidebar-header">
            <span class="esidebar-title">{{ 'manuscript.show.inspector.title'|trans }}</span>
            <span class="esidebar-project-type">
                {% if currentConfig %}{{ currentConfig.labelSingular }}{% else %}{{ element.elementType|upper }}{% endif %}
            </span>
        </div>

        {# ── Paramètres de l'élément ────────────────────────── #}
        <div class="epanel-section accordion--open" data-controller="accordion">
            <button class="epanel-header" type="button" data-action="accordion#toggle">
                {{ ux_icon('lucide:settings-2', {class: 'icon-xs'}) }}
                <span>Paramètres</span>
            </button>
            <div class="epanel-content" data-accordion-target="content">
                <form class="esetting-form"
                      id="settings-form-{{ element.id }}"
                      data-settings-url="{{ settingsUrl }}">

                    {# Résumé — toujours disponible #}
                    <div class="esetting-field">
                        <label class="esetting-label" for="setting-summary-{{ element.id }}">
                            {{ ux_icon('lucide:align-left', {class: 'icon-xs'}) }}
                            Résumé
                        </label>
                        <textarea id="setting-summary-{{ element.id }}"
                                  name="summary"
                                  class="esetting-textarea"
                                  rows="3"
                                  placeholder="Résumé court…">{{ element.summary }}</textarea>
                    </div>

                    {# Durée — uniquement si la config l'autorise #}
                    {% if currentConfig and currentConfig.hasDuration %}
                    <div class="esetting-field">
                        <label class="esetting-label" for="setting-duration-{{ element.id }}">
                            {{ ux_icon('lucide:clock', {class: 'icon-xs'}) }}
                            Durée estimée
                        </label>
                        <div class="esetting-duration-row">
                            <input type="number"
                                   id="setting-duration-{{ element.id }}"
                                   name="durationMinutes"
                                   class="esetting-input esetting-input--short"
                                   value="{{ element.durationSeconds > 0 ? (element.durationSeconds / 60)|round : '' }}"
                                   min="0" max="9999"
                                   placeholder="0">
                            <span class="esetting-unit">min</span>
                            {% if element.durationSeconds > 0 %}
                                <span class="esetting-duration-hint">
                                    ({{ element.durationSeconds }}s)
                                </span>
                            {% endif %}
                        </div>
                    </div>
                    {% endif %}

                    {# Visibilité — uniquement pour les épisodes de séries #}
                    {% if project.projectType == 'serie' and currentConfig and currentConfig.elementType == 'episode' %}
                    <div class="esetting-field">
                        <label class="esetting-label esetting-label--toggle">
                            {{ ux_icon('lucide:globe', {class: 'icon-xs'}) }}
                            <span>Public</span>
                            <label class="esetting-toggle">
                                <input type="checkbox"
                                       name="isPublic"
                                       {% if element.isPublic %}checked{% endif %}>
                                <span class="esetting-toggle-slider"></span>
                            </label>
                        </label>
                        <p class="esetting-hint">Publie cet épisode indépendamment du projet.</p>
                    </div>
                    {% endif %}

                    {# Bouton save + feedback #}
                    <div class="esetting-actions">
                        <button type="submit" class="esetting-save-btn">
                            {{ ux_icon('lucide:save', {class: 'icon-xs'}) }}
                            Sauvegarder
                        </button>
                        <span class="esetting-feedback" id="setting-feedback-{{ element.id }}"></span>
                    </div>

                </form>
            </div>
        </div>

        {# ── Notes liées à CET élément ──────────────────────── #}
        <div class="epanel-section accordion--open" data-controller="accordion">
            <button class="epanel-header" type="button" data-action="accordion#toggle">
                {{ ux_icon('lucide:sticky-note', {class: 'icon-xs'}) }}
                <span>{{ 'manuscript.show.inspector.element_notes'|trans }}</span>
                {% if elementNotes|length > 0 %}
                    <span class="epanel-count epanel-count--warn">{{ elementNotes|length }}</span>
                {% endif %}
            </button>
            <div class="epanel-content" data-accordion-target="content">
                {% if elementNotes is empty %}
                    <p class="edetect-empty">{{ 'manuscript.show.inspector.element_notes_empty'|trans }}</p>
                {% else %}
                    {% for note in elementNotes %}
                        <a href="{{ path('app_note_show', {project_slug: project.slug, id: note.id}) }}"
                           class="epanel-item">
                            <span class="epanel-item-title">{{ note.title }}</span>
                            <span class="epanel-badge epanel-badge--{{ note.status }}">{{ note.status }}</span>
                        </a>
                    {% endfor %}
                {% endif %}
                <div class="epanel-actions">
                    <a href="{{ path('app_note_new', {project_slug: project.slug, element_id: element.id}) }}"
                       class="epanel-add-link">
                        {{ ux_icon('lucide:plus', {class: 'icon-xs'}) }} {{ 'manuscript.show.inspector.new_note'|trans }}
                    </a>
                    {% if elementNotes|length > 0 %}
                        <a href="{{ path('app_note_index', {project_slug: project.slug}) }}"
                           class="epanel-all-link">{{ 'manuscript.show.inspector.all_notes'|trans }}</a>
                    {% endif %}
                </div>
            </div>
        </div>

        {# ── Tâches liées à CET élément ─────────────────────── #}
        <div class="epanel-section" data-controller="accordion">
            <button class="epanel-header" type="button" data-action="accordion#toggle">
                {{ ux_icon('lucide:check-square', {class: 'icon-xs'}) }}
                <span>{{ 'manuscript.show.inspector.element_tasks'|trans }}</span>
                {% if elementTasks|length > 0 %}
                    <span class="epanel-count epanel-count--warn">{{ elementTasks|length }}</span>
                {% endif %}
            </button>
            <div class="epanel-content hidden" data-accordion-target="content">
                {% if elementTasks is empty %}
                    <p class="edetect-empty">{{ 'manuscript.show.inspector.element_tasks_empty'|trans }}</p>
                {% else %}
                    {% for task in elementTasks %}
                        <a href="{{ path('app_task_show', {project_slug: project.slug, id: task.id}) }}"
                           class="epanel-item">
                            <span class="epanel-item-title">{{ task.title }}</span>
                            <span class="epanel-badge epanel-badge--{{ task.status }}">{{ task.status }}</span>
                        </a>
                    {% endfor %}
                {% endif %}
                <div class="epanel-actions">
                    <a href="{{ path('app_task_new', {project_slug: project.slug, element_id: element.id}) }}"
                       class="epanel-add-link">
                        {{ ux_icon('lucide:plus', {class: 'icon-xs'}) }} {{ 'manuscript.show.inspector.new_task'|trans }}
                    </a>
                    {% if elementTasks|length > 0 %}
                        <a href="{{ path('app_task_index', {project_slug: project.slug}) }}"
                           class="epanel-all-link">{{ 'manuscript.show.inspector.all_notes'|trans }}</a>
                    {% endif %}
                </div>
            </div>
        </div>

        {# ── Personnages détectés (feuille seulement) ───────── #}
        {% if element.isLeaf() %}
        <div class="epanel-section" data-controller="accordion">
            <button class="epanel-header" type="button" data-action="accordion#toggle">
                {{ ux_icon('lucide:users', {class: 'icon-xs'}) }}
                <span>{{ 'manuscript.show.inspector.detected_chars'|trans }}</span>
            </button>
            <div class="epanel-content hidden" data-accordion-target="content">
                <div class="edetect-list" data-fountain-editor-target="detectedChars">
                    <p class="edetect-empty">{{ 'manuscript.show.inspector.detected_chars_hint'|trans }}</p>
                </div>
            </div>
        </div>
        {% endif %}

        {# ── Notes globales du projet ───────────────────────── #}
        {% set projectNotes = project.notes|filter(n => n.status != 'archived' and n.linkedEntityType == 'project') %}
        <div class="epanel-section" data-controller="accordion">
            <button class="epanel-header" type="button" data-action="accordion#toggle">
                {{ ux_icon('lucide:folder-open', {class: 'icon-xs'}) }}
                <span>{{ 'manuscript.show.inspector.project_notes'|trans }}</span>
                {% if projectNotes|length > 0 %}
                    <span class="epanel-count">{{ projectNotes|length }}</span>
                {% endif %}
            </button>
            <div class="epanel-content hidden" data-accordion-target="content">
                {% if projectNotes is empty %}
                    <p class="edetect-empty">{{ 'manuscript.show.inspector.project_notes_empty'|trans }}</p>
                {% else %}
                    {% for note in projectNotes|slice(0, 5) %}
                        <a href="{{ path('app_note_show', {project_slug: project.slug, id: note.id}) }}"
                           class="epanel-item">
                            <span class="epanel-item-title">{{ note.title }}</span>
                            <span class="epanel-badge epanel-badge--{{ note.status }}">{{ note.status }}</span>
                        </a>
                    {% endfor %}
                {% endif %}
                <div class="epanel-actions">
                    <a href="{{ path('app_note_index', {project_slug: project.slug}) }}"
                       class="epanel-all-link">{{ 'manuscript.show.inspector.all_project_notes'|trans }}</a>
                </div>
            </div>
        </div>

        {# ── Statistiques (feuille seulement) ───────────────── #}
        {% if element.isLeaf() %}
        <div class="epanel-section" data-controller="accordion">
            <button class="epanel-header" type="button" data-action="accordion#toggle">
                {{ ux_icon('lucide:bar-chart-2', {class: 'icon-xs'}) }}
                <span>{{ 'manuscript.show.inspector.stats'|trans }}</span>
            </button>
            <div class="epanel-content hidden" data-accordion-target="content">
                <div class="edetect-stats">
                    <div class="estat-row">
                        <span>{{ 'manuscript.show.inspector.stat_words'|trans }}</span>
                        <span data-fountain-editor-target="wordCountStat">—</span>
                    </div>
                    <div class="estat-row">
                        <span>{{ 'manuscript.show.inspector.stat_chars'|trans }}</span>
                        <span data-fountain-editor-target="charCountStat">—</span>
                    </div>
                    <hr class="estat-divider">
                    <div class="estat-row estat-row--computed">
                        <span>Pages estimées</span>
                        <span data-fountain-editor-target="estimatedPages">—</span>
                    </div>
                    <div class="estat-row estat-row--computed">
                        <span>Durée à l'écran</span>
                        <span data-fountain-editor-target="estimatedScreenTime">—</span>
                    </div>
                    <div class="estat-row estat-row--computed">
                        <span>Temps de lecture</span>
                        <span data-fountain-editor-target="estimatedReadTime">—</span>
                    </div>
                    <hr class="estat-divider">
                    <div class="estat-row">
                        <span>{{ 'manuscript.show.inspector.stat_last_saved'|trans }}</span>
                        <span data-fountain-editor-target="lastSavedStat">—</span>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

    </aside>
</div>

{# ── Save settings via AJAX ─────────────────────────────────────────── #}
<script>
(function () {
    const form = document.getElementById('settings-form-{{ element.id }}');
    if (!form) return;

    const url      = form.dataset.settingsUrl;
    const feedback = document.getElementById('setting-feedback-{{ element.id }}');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const summaryEl  = form.elements['summary'];
        const durationEl = form.elements['durationMinutes'];
        const publicEl   = form.elements['isPublic'];

        const payload = {
            summary:         summaryEl?.value.trim() ?? '',
            durationSeconds: durationEl ? Math.max(0, parseInt(durationEl.value || '0', 10) * 60) : undefined,
            isPublic:        publicEl ? publicEl.checked : undefined,
        };

        // Retire les clés undefined
        Object.keys(payload).forEach(k => payload[k] === undefined && delete payload[k]);

        try {
            const resp = await fetch(url, {
                method:  'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(payload),
            });

            if (resp.ok) {
                feedback.textContent = '✓ Sauvegardé';
                feedback.className   = 'esetting-feedback esetting-feedback--ok';
            } else {
                feedback.textContent = '✗ Erreur';
                feedback.className   = 'esetting-feedback esetting-feedback--err';
            }
        } catch {
            feedback.textContent = '✗ Erreur réseau';
            feedback.className   = 'esetting-feedback esetting-feedback--err';
        }

        setTimeout(() => { feedback.textContent = ''; feedback.className = 'esetting-feedback'; }, 3000);
    });
})();
</script>
{% endblock %}
