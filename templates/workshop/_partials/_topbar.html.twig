{% trans_default_domain 'workshop' %}

<header class="section-header{% if project is defined %} project-context{% endif %}"
        data-controller="mobile-nav">

    <div class="top-nav">

        {# ── Gauche : logo + liens nav (desktop) ─────────────────── #}
        <div class="nav-left">
            <a href="{{ path('app_home') }}" class="topbar-logo">
                <img src="{{ asset('images/favicons/favicon_workshop.png') }}" alt="Scénart" width="28">
            </a>

            <div class="subnav-links">
                <a href="{{ path('app_workshop_dashboard') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_workshop_dashboard' ? 'active' : '' }}">
                    {{ 'navbar.links.dashboard'|trans }}
                </a>

                <a href="{{ path('app_project_index') }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_project_'
                             and not (app.request.attributes.get('_route') starts with 'app_project_public')
                             ? 'active' : '' }}">
                    {{ 'navbar.links.projects'|trans }}
                    <span class="nav-count">{{ projects_count|default(0) }}</span>
                </a>

                <a href="{{ path('app_workshop_explore', {_locale: app.request.locale}) }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_workshop_explore'
                             or app.request.attributes.get('_route') starts with 'app_project_public'
                             or app.request.attributes.get('_route') starts with 'app_workshop_creator'
                             or app.request.attributes.get('_route') starts with 'app_element_reader'
                             ? 'active' : '' }}">
                    {{ 'navbar.links.explore'|trans }}
                </a>

                <a href="{{ path('app_documentation', {_locale: app.request.locale}) }}"
                   class="{{ app.request.attributes.get('_route') starts with 'app_documentation' ? 'active' : '' }}">
                    {{ 'navbar.links.documentation'|trans }}
                </a>
            </div>
        </div>

        {# ── Burger (mobile uniquement) ──────────────────────────── #}
        <button class="topbar-burger"
                type="button"
                aria-label="{{ 'navbar.actions.open_menu'|trans }}"
                data-action="mobile-nav#toggle">
            {{ ux_icon('lucide:panel-left-open', {class: 'icon-base'}) }}
        </button>

        {# ── Droite : notifs + user ───────────────────────────────── #}
        <div class="nav-right">

            <div class="notification-wrapper"
                 data-controller="notifications"
                 data-notifications-dropdown-url-value="{{ path('app_notifications_dropdown', {_locale: app.request.locale}) }}"
                 data-notifications-mark-all-url-value="{{ path('app_notifications_mark_all_read', {_locale: app.request.locale}) }}"
                 data-notifications-csrf-value="{{ csrf_token('notif_read_all') }}">

                <button class="notification-btn"
                        aria-label="{{ 'navbar.notifications.title'|trans }}"
                        data-action="notifications#toggle"
                        data-notifications-target="btn">
                    {{ ux_icon('lucide:bell', {class: 'icon-sm'}) }}
                    {% if unread_notif_count > 0 %}
                        <span class="notification-badge" data-notifications-target="badge">
                            {{ unread_notif_count > 9 ? '9+' : unread_notif_count }}
                        </span>
                    {% else %}
                        <span class="notification-badge notification-badge--hidden" data-notifications-target="badge"></span>
                    {% endif %}
                </button>

                <div class="notification-dropdown" hidden data-notifications-target="dropdown">
                    <div class="notification-dropdown__header">
                        <span class="notification-dropdown__title">{{ 'navbar.notifications.title'|trans }}</span>
                        <button class="notification-dropdown__mark-all"
                                data-action="notifications#markAllRead">
                            {{ 'navbar.notifications.mark_all'|trans }}
                        </button>
                    </div>
                    <div class="notification-dropdown__list" data-notifications-target="list">
                        <div class="notification-dropdown__loading">
                            {{ ux_icon('lucide:loader', {style: 'width:16px;height:16px'}) }}
                        </div>
                    </div>
                    <a href="{{ path('app_notifications', {_locale: app.request.locale}) }}"
                       class="notification-dropdown__see-all">
                        {{ 'navbar.notifications.see_all'|trans }}
                    </a>
                </div>

            </div>

            <twig:UserProfile />

        </div>

    </div>

    {# ── Drawer mobile (pages sans sidebar projet) ────────────── #}
    <div class="mobile-nav-drawer">
        <div class="mobile-nav-drawer__header">
            <a href="{{ path('app_home') }}" class="topbar-logo">
                <img src="{{ asset('images/favicons/favicon_workshop.png') }}" alt="Scénart" width="32">
            </a>
            <button class="mobile-nav-drawer__close"
                    type="button"
                    data-action="mobile-nav#close"
                    aria-label="Fermer">
                {{ ux_icon('lucide:panel-left-close', {class: 'icon-base'}) }}
            </button>
        </div>

        <nav class="mobile-nav-drawer__links">
            <a href="{{ path('app_home') }}" class="mobile-nav-drawer__back">
                {{ ux_icon('lucide:arrow-left', {class: 'icon-xs'}) }}
                Retour au site
            </a>

            <a href="{{ path('app_workshop_dashboard') }}"
               class="{{ app.request.attributes.get('_route') starts with 'app_workshop_dashboard' ? 'active' : '' }}">
                {{ ux_icon('lucide:layout-dashboard', {class: 'icon-xs'}) }}
                {{ 'navbar.links.dashboard'|trans }}
            </a>
            <a href="{{ path('app_project_index') }}"
               class="{{ app.request.attributes.get('_route') starts with 'app_project_'
                         and not (app.request.attributes.get('_route') starts with 'app_project_public')
                         ? 'active' : '' }}">
                {{ ux_icon('lucide:folder', {class: 'icon-xs'}) }}
                {{ 'navbar.links.projects'|trans }}
                <span class="nav-count">{{ projects_count|default(0) }}</span>
            </a>
            <a href="{{ path('app_workshop_explore', {_locale: app.request.locale}) }}"
               class="{{ app.request.attributes.get('_route') starts with 'app_workshop_explore'
                         or app.request.attributes.get('_route') starts with 'app_project_public'
                         or app.request.attributes.get('_route') starts with 'app_workshop_creator'
                         or app.request.attributes.get('_route') starts with 'app_element_reader'
                         ? 'active' : '' }}">
                {{ ux_icon('lucide:compass', {class: 'icon-xs'}) }}
                {{ 'navbar.links.explore'|trans }}
            </a>
            <a href="{{ path('app_documentation', {_locale: app.request.locale}) }}"
               class="{{ app.request.attributes.get('_route') starts with 'app_documentation' ? 'active' : '' }}">
                {{ ux_icon('lucide:book-open', {class: 'icon-xs'}) }}
                {{ 'navbar.links.documentation'|trans }}
            </a>
        </nav>
    </div>
    <div class="mobile-nav-overlay" data-action="click->mobile-nav#close"></div>

</header>
