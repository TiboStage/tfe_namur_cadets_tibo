{% extends 'workshop/projects/layout.html.twig' %}
{% trans_default_domain 'workshop' %}

{% block title %}{{ 'character.new.title'|trans }} — {{ project.title }}{% endblock %}

{% block project_content %}
<div class="workshop-container">

    {# ── En-tête page (accès direct uniquement, ignoré dans le modal) ── #}
    <header class="page-header">
        <div>
            <a href="{{ path('app_character_index', {project_slug: project.slug}) }}" class="link-back">
                {{ ux_icon('lucide:arrow-left', {class: 'icon-xs'}) }}
                {{ 'character.new.back'|trans }}
            </a>
            <h1>{{ 'character.new.title'|trans }}</h1>
        </div>
    </header>

    {# ── Contenu chargé dans le modal (turbo-frame) ────────────────── #}
    <turbo-frame id="modal-frame">
        <div class="ws-modal-form-wrap">

            <h2 class="ws-modal-form-title">{{ 'character.new.title'|trans }}</h2>

            {{ form_start(form, {
                'attr': {
                    'novalidate': 'novalidate',
                    'class': 'project-form',
                    'data-controller': 'form-validation',
                    'data-action': 'submit->form-validation#submit'
                }
            }) }}

            <div class="character-form-grid">

                {# ── Identité ────────────────────────────────────── #}
                <div>
                    <div class="form-section-title">{{ 'character.form.section_identity'|trans }}</div>

                    {{ form_row(form.name, {
                        'label': 'character.form.name'|trans,
                        'attr': {
                            'minlength': 2,
                            'data-form-validation-target': 'field',
                            'data-action': 'blur->form-validation#validate',
                            'data-error-required':  'character.name.required'|trans({}, 'validators'),
                            'data-error-minlength': 'character.name.too_short'|trans({}, 'validators')
                        }
                    }) }}

                    <div class="form-row-two">
                        {{ form_row(form.firstName, {'label': 'character.form.firstname'|trans}) }}
                        {{ form_row(form.lastName,  {'label': 'character.form.lastname'|trans}) }}
                    </div>

                    {{ form_row(form.nickname,     {'label': 'character.form.nickname'|trans}) }}
                    {{ form_row(form.role,         {'label': 'character.form.role'|trans}) }}
                    {{ form_row(form.description,  {'label': 'character.form.description'|trans, 'attr': {'rows': 3}}) }}
                </div>

                {# ── Psychologie ─────────────────────────────────── #}
                <div>
                    <div class="form-section-title">{{ 'character.form.section_psychology'|trans }}</div>

                    {{ form_row(form.biography,   {'label': 'character.form.biography'|trans,   'attr': {'rows': 5}}) }}
                    {{ form_row(form.goals,       {'label': 'character.form.goals'|trans,       'attr': {'rows': 3}}) }}
                    {{ form_row(form.motivations, {'label': 'character.form.motivations'|trans, 'attr': {'rows': 3}}) }}
                    {{ form_row(form.characterArc,{'label': 'character.form.arc'|trans,         'attr': {'rows': 3}}) }}
                </div>

            </div>

            <div class="form-actions">
                {# Annuler : ferme le modal si présent, sinon non-opérant (type=button) #}
                <button type="button" class="btn-export" data-action="click->modal#close">
                    {{ 'character.new.cancel'|trans }}
                </button>
                <button type="submit" class="btn-creat">
                    {{ 'character.new.submit'|trans }}
                </button>
            </div>

            {{ form_end(form) }}

        </div>
    </turbo-frame>

</div>
{% endblock %}
