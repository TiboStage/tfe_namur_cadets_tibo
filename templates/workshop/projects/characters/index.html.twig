{% extends 'workshop/projects/layout.html.twig' %}
{% trans_default_domain 'workshop_interface' %}

{% block title %}Personnages — {{ project.title }}{% endblock %}

{% block content %}
<div class="dashboard-container">

    <header class="page-header">
        <div>
            <a href="{{ path('app_project_show', {slug: project.slug}) }}" class="link-back">← {{ project.title }}</a>
            <h1>Personnages <span class="text-muted" style="font-size: 16px; font-weight: 400;">{{ characters|length }}</span></h1>
        </div>
        <a href="{{ path('app_character_new', {project_slug: project.slug}) }}" class="btn-creat">
            + Nouveau personnage
        </a>
    </header>

    {% if characters is empty %}
        <div class="empty-projects">
            <p class="text-muted">Aucun personnage pour l'instant.</p>
            <a href="{{ path('app_character_new', {project_slug: project.slug}) }}" class="btn-creat">
                Créer le premier personnage
            </a>
        </div>
    {% else %}
        <div class="characters-grid">
            {% for character in characters %}
                <a href="{{ path('app_character_show', {project_slug: project.slug, id: character.id}) }}" class="character-card">
                    <div class="character-card-avatar">
                        {{ character.name|first|upper }}
                    </div>
                    <div class="character-card-info">
                        <span class="character-card-name">{{ character.name }}</span>
                        <span class="character-card-role text-muted">{{ character.role|default('—') }}</span>
                    </div>
                    <span class="project-type-badge">{{ character.role }}</span>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
