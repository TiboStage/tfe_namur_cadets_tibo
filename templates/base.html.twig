<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Scénart{% endblock %}</title>

    {% block favicon %}
        <link rel="icon" type="image/png" href="{{ asset('images/favicons/favicon.png') }}">
    {% endblock %}

    {% block javascripts %}
        {{ importmap('app') }}
    {% endblock %}

    {% block stylesheets %}{% endblock %}
</head>
<body>

{% block body %}{% endblock %}

{# ✅ AJOUTE CECI JUSTE AVANT </body> #}
<div id="toast-container" class="toast-container" data-controller="toast">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="scenart-alert alert-{{ label }}"
                 data-toast-auto-close-value="true"
                 data-toast-duration-value="5000">
                <div class="alert-icon">
                    <i data-lucide="{% if label == 'success' %}check-circle{% elseif label == 'warning' %}triangle-alert{% elseif label == 'error' %}x-circle{% else %}info{% endif %}"></i>
                </div>
                <div class="alert-body">
                    <p>{{ message|trans }}</p>
                </div>
                <button class="alert-close" data-action="click->toast#close">&times;</button>
            </div>
        {% endfor %}
    {% endfor %}
</div>

</body>
</html>
