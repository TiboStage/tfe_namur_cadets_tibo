{% extends 'workshop/projects/layout.html.twig' %}

{% block title %}Paramètres — {{ project.title }}{% endblock %}

{% block project_content %}

{% set type_labels = {film: 'settings.types.film'|trans({}, 'workshop'), serie: 'settings.types.serie'|trans({}, 'workshop'), jeu_video: 'settings.types.jeu_video'|trans({}, 'workshop'), custom: 'settings.types.custom'|trans({}, 'workshop')} %}
{% set status_labels = {draft: 'settings.statuses.draft'|trans({}, 'workshop'), in_progress: 'settings.statuses.in_progress'|trans({}, 'workshop'), completed: 'settings.statuses.completed'|trans({}, 'workshop'), archived: 'settings.statuses.archived'|trans({}, 'workshop')} %}

<div class="ps-wrapper">

    {# ── Header ───────────────────────────────────────────────────── #}
    <div class="ps-header">
        <div class="ps-header__meta">
            <a href="{{ path('app_project_show', {_locale: app.request.locale, slug: project.slug}) }}"
               class="ps-header__back">
                {{ ux_icon('lucide:arrow-left', {style: 'width:13px;height:13px'}) }}
                {{ project.title }}
            </a>
            <h1 class="ps-header__title">{{ 'settings.title'|trans({}, 'workshop') }}</h1>
        </div>
    </div>

    {# ── Onglets ──────────────────────────────────────────────────── #}
    <nav class="ps-tabs" aria-label="{{ 'settings.tabs.label'|trans({}, 'workshop') }}">
        {% set tabs_map = {
            general:     {label: 'settings.tabs.general'|trans({}, 'workshop'),    icon: 'lucide:settings-2'},
            structure:   {label: 'settings.tabs.structure'|trans({}, 'workshop'),  icon: 'lucide:git-branch'},
            members:     {label: 'settings.tabs.members'|trans({}, 'workshop'),    icon: 'lucide:users'},
            permissions: {label: 'Permissions',                                    icon: 'lucide:shield'},
            danger:      {label: 'settings.tabs.danger'|trans({}, 'workshop'),     icon: 'lucide:triangle-alert'},
        } %}
        {% for t, meta in tabs_map %}
            {% if t != 'permissions' or isOwner %}
            <a href="{{ path('app_project_edit', {_locale: app.request.locale, slug: project.slug, tab: t}) }}"
               class="ps-tab {{ tab == t ? 'ps-tab--active' : '' }} {{ t == 'danger' ? 'ps-tab--danger' : '' }}">
                {{ ux_icon(meta.icon, {style: 'width:13px;height:13px'}) }}
                {{ meta.label }}
            </a>
            {% endif %}
        {% endfor %}
    </nav>

    {# ── Erreurs ──────────────────────────────────────────────────── #}
    {% if errors is defined and errors|length > 0 %}
    <div class="ps-alert ps-alert--error">
        {% for err in errors %}{{ err }}{% if not loop.last %}<br>{% endif %}{% endfor %}
    </div>
    {% endif %}

    {# ══════════════════════════════════════════════════════════════
       ONGLET INFORMATIONS
       ══════════════════════════════════════════════════════════════ #}
    {% if tab == 'general' %}
    <div class="ps-panel">

        <form method="post"
              action="{{ path('app_project_edit', {_locale: app.request.locale, slug: project.slug, tab: 'general'}) }}"
              class="ps-form"
              novalidate>
            <input type="hidden" name="_action" value="save_general">
            <input type="hidden" name="_token"  value="{{ csrf_token('project_settings_' ~ project.id) }}">

            <div class="ps-section">
                <div class="ps-section__head">
                    <div class="ps-section__title-row">
                        {{ ux_icon('lucide:file-text', {class: 'icon-xs'}) }}
                        <h2>{{ 'settings.general.title'|trans({}, 'workshop') }}</h2>
                    </div>
                    <p class="text-muted">{{ 'settings.general.hint'|trans({}, 'workshop') }}</p>
                </div>

                <div class="ps-field">
                    <label class="ps-label">{{ 'settings.general.field_title'|trans({}, 'workshop') }} <span class="ps-required">*</span></label>
                    <input type="text" name="title" class="ps-input"
                           value="{{ project.title }}" maxlength="150" required>
                </div>

                <div class="ps-field">
                    <label class="ps-label">{{ 'settings.general.field_description'|trans({}, 'workshop') }} <span class="ps-optional">{{ 'settings.general.optional'|trans({}, 'workshop') }}</span></label>
                    <textarea name="description" class="ps-textarea" rows="4">{{ project.description }}</textarea>
                </div>

                <div class="ps-row">
                    <div class="ps-field">
                        <label class="ps-label">{{ 'settings.general.field_type'|trans({}, 'workshop') }}</label>
                        <div class="ps-input ps-input--readonly">
                            {{ type_labels[project.projectType] ?? project.projectType }}
                            <span class="ps-readonly-hint">{{ 'settings.general.type_readonly'|trans({}, 'workshop') }}</span>
                        </div>
                    </div>
                    <div class="ps-field">
                        <label class="ps-label">{{ 'settings.general.field_status'|trans({}, 'workshop') }}</label>
                        <select name="status" class="ps-select">
                            {% for val, lbl in status_labels %}
                            <option value="{{ val }}" {{ project.status == val ? 'selected' }}>{{ lbl }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
            </div>

            {# ── Genres ──────────────────────────────────────────────────── #}
            {% if available_genres is not empty %}
            <div class="ps-section">
                <div class="ps-section__head">
                    <div class="ps-section__title-row">
                        {{ ux_icon('lucide:tag', {class: 'icon-xs'}) }}
                        <h2>{{ 'settings.genres.title'|trans({}, 'workshop') }}</h2>
                    </div>
                    <p class="text-muted">
                        {{ 'settings.genres.hint'|trans({}, 'workshop') }}
                    </p>
                </div>

                <div class="ps-genre-search-wrap">
                    <input type="text"
                           id="ps-genre-search"
                           class="ps-genre-search"
                           placeholder="{{ 'settings.genres.search_placeholder'|trans({}, 'workshop') }}"
                           autocomplete="off"
                           spellcheck="false">
                    <svg class="ps-genre-search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                </div>

                <div class="ps-genre-grid" id="ps-genre-grid">
                    {% for genre in available_genres %}
                    {% set isChecked = genre.slug in selected_genre_slugs %}
                    <label class="ps-genre-chip {{ isChecked ? 'ps-genre-chip--checked' : '' }}"
                           data-label="{{ genre.getLabel(app.request.locale)|lower }}">
                        <input type="checkbox"
                               name="genres[]"
                               value="{{ genre.slug }}"
                               class="ps-genre-checkbox"
                               {{ isChecked ? 'checked' : '' }}>
                        <span>{{ genre.getLabel(app.request.locale) }}</span>
                    </label>
                    {% endfor %}
                </div>
                <p class="ps-genre-no-results" id="ps-genre-no-results" style="display:none">
                    {{ 'settings.genres.no_results'|trans({}, 'workshop') }}
                </p>
            </div>
            {% endif %}

            <script>
            (function () {
                const chips     = document.querySelectorAll('.ps-genre-chip');
                const search    = document.getElementById('ps-genre-search');
                const noResults = document.getElementById('ps-genre-no-results');

                if (!search) return;

                search.addEventListener('input', function () {
                    const q = this.value.toLowerCase().trim();
                    let visible = 0;
                    chips.forEach(chip => {
                        const label     = chip.dataset.label || '';
                        const isChecked = chip.querySelector('.ps-genre-checkbox').checked;
                        const show      = !q || isChecked || label.includes(q);
                        chip.style.display = show ? '' : 'none';
                        if (show) visible++;
                    });
                    if (noResults) noResults.style.display = (visible === 0) ? '' : 'none';
                });
            })();
            </script>

            {# ── Paramètres du manuscrit ──────────────────────────────── #}
            <div class="ps-section">
                <div class="ps-section__head">
                    <div class="ps-section__title-row">
                        {{ ux_icon('lucide:book-open', {class: 'icon-xs'}) }}
                        <h2>{{ 'settings.manuscript.title'|trans({}, 'workshop') }}</h2>
                    </div>
                    <p class="text-muted">
                        {{ 'settings.manuscript.hint'|trans({}, 'workshop') }}
                    </p>
                </div>

                <div class="ps-row ps-row--3cols">
                    <div class="ps-field">
                        <label class="ps-label">
                            {{ 'settings.manuscript.words_per_page'|trans({}, 'workshop') }}
                            <span class="ps-optional">{{ 'settings.manuscript.words_per_page_default'|trans({}, 'workshop') }}</span>
                        </label>
                        <div class="ps-input-group">
                            <input type="number" name="ms_words_per_page" class="ps-input"
                                   value="{{ project.settings.ms_words_per_page ?? 170 }}"
                                   min="1" max="999">
                            <span class="ps-input-addon">{{ 'settings.manuscript.unit_words'|trans({}, 'workshop') }}</span>
                        </div>
                    </div>

                    <div class="ps-field">
                        <label class="ps-label">
                            Vitesse de lecture
                            <span class="ps-optional">(std : 200)</span>
                        </label>
                        <div class="ps-input-group">
                            <input type="number" name="ms_reading_wpm" class="ps-input"
                                   value="{{ project.settings.ms_reading_wpm ?? 200 }}"
                                   min="1" max="9999">
                            <span class="ps-input-addon">mots/min</span>
                        </div>
                    </div>

                    <div class="ps-field">
                        <label class="ps-label">
                            Durée à l'écran
                            <span class="ps-optional">(std : 60 s/page)</span>
                        </label>
                        <div class="ps-input-group">
                            <input type="number" name="ms_screen_time_per_page" class="ps-input"
                                   value="{{ project.settings.ms_screen_time_per_page ?? 60 }}"
                                   min="1" max="999">
                            <span class="ps-input-addon">s / page</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="ps-actions">
                <button type="submit" class="btn btn--cta-yellow">
                    {{ ux_icon('lucide:check', {class: 'icon-xs'}) }}
                    {{ 'settings.btn.save'|trans({}, 'workshop') }}
                </button>
                <a href="{{ path('app_project_show', {_locale: app.request.locale, slug: project.slug}) }}"
                   class="btn btn--ghost">{{ 'settings.btn.cancel'|trans({}, 'workshop') }}</a>
            </div>
        </form>

    </div>
    {% endif %}

    {# ══════════════════════════════════════════════════════════════
       ONGLET STRUCTURE
       ══════════════════════════════════════════════════════════════ #}
    {% if tab == 'structure' %}
    <div class="ps-panel">

        <form method="post"
              action="{{ path('app_project_edit', {_locale: app.request.locale, slug: project.slug, tab: 'structure'}) }}"
              class="ps-form"
              novalidate>
            <input type="hidden" name="_action" value="save_structure">
            <input type="hidden" name="_token"  value="{{ csrf_token('project_structure_' ~ project.id) }}">

            <div class="ps-section">
                <div class="ps-section__head">
                    <div class="ps-section__title-row">
                        {{ ux_icon('lucide:git-branch', {class: 'icon-xs'}) }}
                        <h2>{{ 'settings.narrative.title'|trans({}, 'workshop') }}</h2>
                    </div>
                    <p class="text-muted">
                        Modifiez les noms affichés pour chaque niveau de votre structure.
                        Le nombre de niveaux ne peut pas être changé après création.
                    </p>
                </div>

                {% set level_colors = ['#E63946', '#F4A261', '#457B9D', '#2A9D8F'] %}

                {% if configs is empty %}
                    <p class="text-muted">Aucune structure définie pour ce projet.</p>
                {% else %}
                    <div class="ps-level-list">
                        {% for config in configs %}
                        {% set color = level_colors[config.depth - 1] ?? '#888' %}
                        <div class="ps-level-row">
                            <span class="ps-level-badge" style="--badge-color: {{ color }}">
                                N{{ config.depth }}
                            </span>

                            <div class="ps-level-fields">
                                <div class="ps-field ps-field--inline">
                                    <label class="ps-label">Singulier</label>
                                    <input type="text"
                                           name="configs[{{ config.id }}][labelSingular]"
                                           class="ps-input"
                                           value="{{ config.labelSingular }}"
                                           maxlength="40" required>
                                </div>
                                <div class="ps-field ps-field--inline">
                                    <label class="ps-label">Pluriel</label>
                                    <input type="text"
                                           name="configs[{{ config.id }}][labelPlural]"
                                           class="ps-input"
                                           value="{{ config.labelPlural }}"
                                           maxlength="40">
                                </div>
                            </div>

                            <div class="ps-level-flags">
                                {% if config.hasContent %}
                                <span class="ps-flag ps-flag--green">contenu</span>
                                {% endif %}
                                {% if config.hasDuration %}
                                <span class="ps-flag ps-flag--blue">durée</span>
                                {% endif %}
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="ps-actions">
                <button type="submit" class="btn btn--cta-yellow">
                    {{ ux_icon('lucide:check', {class: 'icon-xs'}) }}
                    Enregistrer la structure
                </button>
            </div>
        </form>

    </div>
    {% endif %}

    {# ══════════════════════════════════════════════════════════════
       ONGLET COLLABORATEURS
       ══════════════════════════════════════════════════════════════ #}
    {% if tab == 'members' %}
    <div class="ps-panel">

        <div class="ps-section">
            <div class="ps-section__head">
                <div class="ps-section__title-row">
                    {{ ux_icon('lucide:user-plus', {class: 'icon-xs'}) }}
                    <h2>{{ 'settings.invite.title'|trans({}, 'workshop') }}</h2>
                </div>
                <p class="text-muted">{{ 'settings.invite.placeholder'|trans({}, 'workshop') }}</p>
            </div>

            <form method="post"
                  action="{{ path('app_project_member_invite', {_locale: app.request.locale, slug: project.slug}) }}"
                  class="ps-invite-form">
                <input type="hidden" name="_token" value="{{ csrf_token('member_invite_' ~ project.id) }}">

                <div class="ps-invite-row">
                    <div class="ps-field flex-1">
                        <label class="ps-label">Nom d'utilisateur</label>
                        <input type="text" name="username" class="ps-input"
                               placeholder="ex : alice_writes" required autocomplete="off">
                    </div>
                    <div class="ps-field flex-1">
                        <label class="ps-label">Rôle</label>
                        <select name="role" class="ps-select">
                            <option value="contributor">Contributeur — lecture + suggestions</option>
                            <option value="editor">Éditeur — peut modifier le contenu</option>
                            <option value="lead">Co-responsable — accès complet</option>
                        </select>
                    </div>
                    <div class="ps-field ps-field--submit">
                        <label class="ps-label">&nbsp;</label>
                        <button type="submit" class="btn btn--cta-yellow">
                            {{ ux_icon('lucide:user-plus', {style: 'width:13px;height:13px'}) }}
                            Inviter
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="ps-section">
            <div class="ps-section__head">
                <div class="ps-section__title-row">
                    {{ ux_icon('lucide:users', {class: 'icon-xs'}) }}
                    <h2>{{ 'settings.members_list.title'|trans({}, 'workshop') }}</h2>
                </div>
            </div>

            {% if project.projectMembers is empty %}
            <p class="text-muted ps-empty">
                {{ ux_icon('lucide:user-x', {class: 'icon-xs'}) }}
                Aucun collaborateur pour l'instant.
            </p>
            {% else %}
            <div class="ps-member-list">
                {% for member in project.projectMembers %}
                <div class="ps-member-row">
                    <div class="ps-member-avatar">
                        {{ include('_partials/_user_avatar.html.twig', {user: member.user, size: 'sm'}) }}
                    </div>
                    <div class="ps-member-info">
                        <span class="ps-member-username">{{ member.user.username }}</span>
                        <span class="ps-member-since text-muted">depuis {{ member.joinedAt|date('d/m/Y') }}</span>
                    </div>

                    <form method="post"
                          action="{{ path('app_project_member_role', {_locale: app.request.locale, slug: project.slug, userId: member.user.id}) }}"
                          class="ps-role-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('member_role_' ~ project.id ~ '_' ~ member.user.id) }}">
                        <select name="role" class="ps-select ps-select--small"
                                onchange="this.closest('form').submit()">
                            <option value="contributor" {{ member.role == 'contributor' ? 'selected' }}>Contributeur</option>
                            <option value="editor"      {{ member.role == 'editor'      ? 'selected' }}>Éditeur</option>
                            <option value="lead"        {{ member.role == 'lead'        ? 'selected' }}>Co-responsable</option>
                        </select>
                    </form>

                    <form method="post"
                          action="{{ path('app_project_member_remove', {_locale: app.request.locale, slug: project.slug, userId: member.user.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('member_remove_' ~ project.id ~ '_' ~ member.user.id) }}">
                        <button type="submit" class="ps-remove-btn"
                                title="{{ 'settings.members_list.remove_title'|trans({'%username%': member.user.username}, 'workshop') }}"
                                onclick="return confirm('Retirer {{ member.user.username }} du projet ?')">
                            {{ ux_icon('lucide:x', {style: 'width:13px;height:13px'}) }}
                        </button>
                    </form>
                </div>
                {% endfor %}
            </div>
            {% endif %}
        </div>

    </div>
    {% endif %}

    {# ══════════════════════════════════════════════════════════════
       ONGLET PERMISSIONS
       ══════════════════════════════════════════════════════════════ #}
    {% if tab == 'permissions' and isOwner %}
    <div class="ps-panel">

        <div class="ps-section">
            <div class="ps-section__head">
                <div class="ps-section__title-row">
                    {{ ux_icon('lucide:shield', {class: 'icon-xs'}) }}
                    <h2>Permissions par rôle</h2>
                </div>
                <p class="text-muted">
                    Définissez ce que chaque rôle peut faire dans ce projet.
                    Le propriétaire a toujours accès à tout.
                    <a href="{{ path('app_project_moderation', {_locale: app.request.locale, slug: project.slug}) }}"
                       class="ps-link-inline">
                        {{ ux_icon('lucide:arrow-up-right', {style: 'width:11px;height:11px'}) }}
                        Voir la modération
                    </a>
                </p>
            </div>

            <form method="post"
                  action="{{ path('app_project_edit', {_locale: app.request.locale, slug: project.slug, tab: 'permissions'}) }}"
                  class="ps-form">
                <input type="hidden" name="_action" value="save_permissions">
                <input type="hidden" name="_token"  value="{{ csrf_token('project_permissions_' ~ project.id) }}">

                <div class="ps-perm-grid">

                    {# ── En-tête : labels des rôles ── #}
                    <div class="ps-perm-header">
                        <div class="ps-perm-feature-col"></div>
                        {% for role in permRoles %}
                        <div class="ps-perm-role-col ps-perm-role-col--{{ roleColors[role] }}">
                            <span class="ps-perm-role-name">{{ roleLabels[role] }}</span>
                            <button type="submit" name="reset_{{ role }}" value="1"
                                    class="ps-perm-reset-btn"
                                    title="Réinitialiser aux valeurs par défaut"
                                    onclick="return confirm('Réinitialiser les permissions de {{ roleLabels[role] }} aux valeurs par défaut ?')">
                                {{ ux_icon('lucide:rotate-ccw', {style: 'width:10px;height:10px'}) }}
                            </button>
                        </div>
                        {% endfor %}
                    </div>

                    {# ── Lignes par groupe ── #}
                    {% for groupKey, perms in permGroups %}
                    <div class="ps-perm-group">
                        <div class="ps-perm-group-label">
                            {{ ux_icon(groupIcons[groupKey], {style: 'width:12px;height:12px'}) }}
                            {{ groupLabels[groupKey] }}
                        </div>

                        {% for permKey, permLabel in perms %}
                        <div class="ps-perm-row">
                            <div class="ps-perm-feature-col">
                                <span class="ps-perm-label">{{ permLabel }}</span>
                                <code class="ps-perm-key">{{ permKey }}</code>
                            </div>
                            {% for role in permRoles %}
                            <div class="ps-perm-role-col">
                                <label class="ps-perm-check">
                                    <input type="checkbox"
                                           class="ps-perm-check-box"
                                           name="permissions[{{ role }}][]"
                                           value="{{ permKey }}"
                                           {% if permKey in effectivePerms[role] %}checked{% endif %}>
                                </label>
                            </div>
                            {% endfor %}
                        </div>
                        {% endfor %}
                    </div>
                    {% endfor %}

                </div>

                <div class="ps-perm-actions">
                    <button type="submit" class="btn btn--cta-yellow">
                        {{ ux_icon('lucide:save', {style: 'width:13px;height:13px'}) }}
                        Enregistrer les permissions
                    </button>
                </div>
            </form>
        </div>

    </div>
    {% endif %}

    {# ══════════════════════════════════════════════════════════════
       ONGLET DANGER
       ══════════════════════════════════════════════════════════════ #}
    {% if tab == 'danger' %}
    <div class="ps-panel">

        <div class="ps-section ps-section--danger">
            <div class="ps-section__head">
                <div class="ps-section__title-row">
                    {{ ux_icon('lucide:trash-2', {class: 'icon-xs'}) }}
                    <h2>{{ 'settings.danger.title'|trans({}, 'workshop') }}</h2>
                </div>
                <p class="text-muted">
                    Cette action est <strong>irréversible</strong>. Tout le contenu (personnages, lieux, manuscrit,
                    notes, tâches) sera définitivement supprimé.
                </p>
            </div>

            <form method="post"
                  action="{{ path('app_project_delete', {_locale: app.request.locale, slug: project.slug}) }}"
                  onsubmit="return confirm('Supprimer définitivement « {{ project.title }} » ? Cette action est irréversible.')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_project_' ~ project.id) }}">
                <button type="submit" class="btn btn--danger">
                    {{ ux_icon('lucide:trash-2', {class: 'icon-xs'}) }}
                    Supprimer « {{ project.title }} »
                </button>
            </form>
        </div>

    </div>
    {% endif %}

</div>

{% endblock %}
