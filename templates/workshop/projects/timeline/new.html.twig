{% extends 'workshop/projects/layout.html.twig' %}
{% trans_default_domain 'workshop' %}

{% block title %}{{ 'world_event.new.title'|trans }} — {{ project.title }}{% endblock %}

{% block project_content %}
    <div class="dashboard-container">

        {# ── En-tête page (accès direct uniquement) ──────────────────── #}
        <header class="page-header">
            <div>
                <a href="{{ path('app_world_event_index', {project_slug: project.slug}) }}" class="link-back">
                    {{ ux_icon('lucide:arrow-left', {class: 'icon-xs'}) }}
                    {{ 'world_event.back'|trans }}
                </a>
                <h1>{{ 'world_event.new.title'|trans }}</h1>
            </div>
        </header>

        <div class="ws-modal-form-wrap">

            <h2 class="ws-modal-form-title">{{ 'world_event.new.title'|trans }}</h2>

            {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'project-form'}}) }}

            <div class="form-section">
                <div class="form-section-title">{{ 'world_event.form.section_main'|trans }}</div>
                {{ form_row(form.title,       {'attr': {'placeholder': 'world_event.form.title.placeholder'|trans}}) }}
                {{ form_row(form.description, {'attr': {'placeholder': 'world_event.form.description.placeholder'|trans, 'rows': 5}}) }}
            </div>

            <div class="form-section">
                <div class="form-section-title">{{ 'world_event.form.section_date'|trans }}</div>
                <p class="form-section-help">{{ 'world_event.form.date_help'|trans }}</p>
                <div class="form-row-group">
                    {{ form_row(form.year,  {'attr': {'placeholder': 'world_event.form.year.placeholder'|trans}}) }}
                    {{ form_row(form.month, {'attr': {'placeholder': 'world_event.form.month.placeholder'|trans}}) }}
                    {{ form_row(form.day,   {'attr': {'placeholder': 'world_event.form.day.placeholder'|trans}}) }}
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">Catégorie &amp; liens</div>
                <div class="form-row-group">
                    {{ form_row(form.eventType) }}
                    {{ form_row(form.linkedScene) }}
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">{{ 'world_event.form.section_location'|trans }}</div>
                {{ form_row(form.location) }}
            </div>

            <div class="form-actions">
                <a href="{{ path('app_world_event_index', {project_slug: project.slug}) }}" class="btn-export">
                    {{ 'common.cancel'|trans }}
                </a>
                <button type="submit" class="btn-creat">{{ 'common.create'|trans }}</button>
            </div>

            {{ form_end(form) }}

        </div>

    </div>
{% endblock %}
