{% extends 'workshop/projects/layout.html.twig' %}
{% trans_default_domain 'workshop' %}

{% block title %}{{ character.name }} — {{ project.title }}{% endblock %}

{% block project_content %}
    <div class="dashboard-container">

        <header class="page-header">
            <div>
                <a href="{{ path('app_character_index', {project_slug: project.slug}) }}" class="link-back">
                    {{ 'character.show.back'|trans }}
                </a>
                <h1>
                    {{ character.name }}
                    {% if character.role %}
                        <span class="project-type-badge">{{ character.role }}</span>
                    {% endif %}
                </h1>
                {% if character.nickname %}
                    <p class="text-muted">« {{ character.nickname }} »</p>
                {% endif %}
            </div>
            <a href="{{ path('app_character_edit', {project_slug: project.slug, id: character.id}) }}" class="btn-export">
                {{ 'character.show.edit_btn'|trans }}
            </a>
        </header>

        <div class="character-show-grid">

            {# ── Contenu principal ─────────────────────────────────────────── #}
            <div class="character-main">

                {% if character.description %}
                    <div class="profile-section">
                        <div class="profile-section-header">
                            <h2>{{ 'character.show.description'|trans }}</h2>
                        </div>
                        <p>{{ character.description }}</p>
                    </div>
                {% endif %}

                {% if character.biography %}
                    <div class="profile-section">
                        <div class="profile-section-header">
                            <h2>{{ 'character.show.biography'|trans }}</h2>
                        </div>
                        <p>{{ character.biography }}</p>
                    </div>
                {% endif %}

                {% if character.goals %}
                    <div class="profile-section">
                        <div class="profile-section-header">
                            <h2>{{ 'character.show.goals'|trans }}</h2>
                        </div>
                        <p>{{ character.goals }}</p>
                    </div>
                {% endif %}

                {% if character.motivations %}
                    <div class="profile-section">
                        <div class="profile-section-header">
                            <h2>{{ 'character.show.motivations'|trans }}</h2>
                        </div>
                        <p>{{ character.motivations }}</p>
                    </div>
                {% endif %}

                {% if character.characterArc %}
                    <div class="profile-section">
                        <div class="profile-section-header">
                            <h2>{{ 'character.show.arc'|trans }}</h2>
                        </div>
                        <p>{{ character.characterArc }}</p>
                    </div>
                {% endif %}

            </div>

            {# ── Sidebar ───────────────────────────────────────────────────── #}
            <aside class="character-sidebar">
                <div class="profile-section">
                    <div class="profile-section-header">
                        <h2>{{ 'character.info.title'|trans }}</h2>
                    </div>
                    <div class="stat-row">
                        <span class="text-muted">{{ 'character.info.firstname'|trans }}</span>
                        <span>{{ character.firstName|default('—') }}</span>
                    </div>
                    <div class="stat-row">
                        <span class="text-muted">{{ 'character.info.lastname'|trans }}</span>
                        <span>{{ character.lastName|default('—') }}</span>
                    </div>
                    <div class="stat-row">
                        <span class="text-muted">{{ 'character.info.role'|trans }}</span>
                        <span>{{ character.role|default('—') }}</span>
                    </div>
                    <div class="stat-row">
                        <span class="text-muted">{{ 'character.info.created_at'|trans }}</span>
                        <span>{{ character.createdAt|date('d/m/Y') }}</span>
                    </div>
                </div>

                {# ── Relations ─────────────────────────────────────────────── #}
                <div class="profile-section">
                    <div class="profile-section-header">
                        <h2>{{ 'character.info.relations'|trans }}</h2>
                    </div>
                    {% set relations = character.getAllRelations() %}
                    {% if relations is empty %}
                        <p class="text-muted">{{ 'character.info.no_relations'|trans }}</p>
                    {% else %}
                        {% for relation in relations %}
                            <div class="stat-row">
                                {% set other = relation.characterA == character ? relation.characterB : relation.characterA %}
                                <span>{{ other.name }}</span>
                                <span class="project-type-badge">{{ relation.relationType }}</span>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </aside>

        </div>
    </div>
{% endblock %}
