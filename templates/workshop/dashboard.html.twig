{% extends 'workshop/layout.html.twig' %}

{% trans_default_domain 'workshop' %}

{% block title %}L'Atelier - Scénart{% endblock %}

{% block content %}
    <div class="workshop-container">
        <div class="container-dashboard-structure">

            <div class="intro-dashboard-structure">

                {# ── EN-TÊTE ─────────────────────────────────────────────── #}
                <header class="dashboard-intro">
                    <h1>
                        {{ 'dashboard.greeting'|trans }}
                        <span class="highlight">{{ app.user.firstName|default('dashboard.default_author'|trans) }}</span>
                    </h1>
                    <p class="text-muted">
                        {{ "now"|date("l d F Y") }} — {{ projects_count }} {{ 'dashboard.subtitle'|trans }}
                    </p>
                </header>

                {# ── STATS ───────────────────────────────────────────────── #}
                <div class="admin-stats-grid">

                    {% set icon_folder %}
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                    {% endset %}
                    {% set sub_projects %}<a href="{{ path('app_project_index') }}" class="color-inherit">{{ 'dashboard.stats.projects_link'|trans }}</a>{% endset %}
                    {{ include('components/_stat_card.html.twig', {
                        icon:  icon_folder,
                        value: projects_count,
                        label: 'dashboard.stats.projects_value'|trans,
                        sub:   sub_projects,
                        color: 'yellow',
                    }) }}

                    {% set icon_users %}
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    {% endset %}
                    {{ include('components/_stat_card.html.twig', {
                        icon:  icon_users,
                        value: total_characters,
                        label: 'dashboard.stats.characters'|trans,
                        color: 'blue',
                    }) }}

                    {% set icon_map %}
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {% endset %}
                    {{ include('components/_stat_card.html.twig', {
                        icon:  icon_map,
                        value: total_locations,
                        label: 'dashboard.stats.locations'|trans,
                        color: 'muted',
                    }) }}

                    {% set icon_film %}
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/></svg>
                    {% endset %}
                    {{ include('components/_stat_card.html.twig', {
                        icon:  icon_film,
                        value: total_scenes,
                        label: 'dashboard.stats.scenes'|trans,
                        color: 'muted',
                    }) }}

                </div>

                {# ── GRILLE BASSE ─────────────────────────────────────────── #}
                <div class="dashboard-lower-grid">

                    {# Projets en cours #}
                    <section class="dashboard-section">
                        <div class="dashboard-section-header">
                            <h2>{{ 'dashboard.projects.title'|trans }}</h2>
                            <a href="{{ path('app_project_index') }}" class="link-more">
                                {{ 'dashboard.projects.see_more'|trans }}
                            </a>
                        </div>

                        <div class="project-list">
                            {% if projects is empty %}
                                <p class="text-muted empty-state">{{ 'dashboard.projects.empty'|trans }}</p>
                            {% else %}
                                {% for project in projects|slice(0, 4) %}
                                    <a href="{{ path('app_project_show', {slug: project.slug}) }}" class="project-list-item">
                                        <div class="project-thumb">{{ project.title|first|upper }}</div>
                                        <div class="project-info">
                                            <span class="project-title">{{ project.title }}</span>
                                            <span class="project-meta text-muted">
                                                {{ project.projectType }} — {{ project.updatedAt|date('d/m/Y') }}
                                            </span>
                                        </div>
                                        <span class="status-badge status-badge--{{ project.status }}">{{ project.status }}</span>
                                    </a>
                                {% endfor %}
                            {% endif %}
                        </div>
                    </section>

                    {# Activité récente #}
                    <section class="dashboard-section">
                        <div class="dashboard-section-header">
                            <h2>{{ 'dashboard.activity.title'|trans }}</h2>
                            <a href="{{ path('app_project_index') }}" class="link-more">{{ 'dashboard.activity.see_all'|trans }}</a>
                        </div>

                        <div class="activity-list">
                            {% if recentProjects is empty %}
                                <p class="text-muted empty-state">{{ 'dashboard.projects.empty'|trans }}</p>
                            {% else %}
                                {% for project in recentProjects %}
                                    <a href="{{ path('app_project_show', {slug: project.slug}) }}" class="activity-item">
                                        <span class="activity-dot"></span>
                                        <div class="activity-text">
                                            <p><strong>{{ project.title }}</strong></p>
                                            <span class="text-muted">{{ project.updatedAt|date('d/m/Y à H:i') }}</span>
                                        </div>
                                        <span class="status-badge status-badge--{{ project.status }}">{{ project.status }}</span>
                                    </a>
                                {% endfor %}
                            {% endif %}
                        </div>
                    </section>

                </div>

            </div>

            {# ── ACTIONS RAPIDES (colonne droite) ─────────────────────── #}
            <div class="child-dashboard-structure">
                <div class="action-stack">
                    <div class="dashboard-section-header">
                        <h2>{{ 'dashboard.quick_actions.title'|trans }}</h2>
                    </div>
                    <div class="quick-action-card-structure">
                        <div class="quick-action-card">
                            <a href="{{ path('app_project_new') }}" class="btn-creat">
                                {{ 'dashboard.actions.new_project_btn'|trans }}
                            </a>
                        </div>
                        <div class="quick-action-card">
                            <button class="btn-export">{{ 'dashboard.actions.export_btn'|trans }}</button>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        {# ── PROJETS RÉCENTS (grille de cartes) ───────────────────────── #}
        <section class="dashboard-section recent-projects-full">
            <div class="dashboard-section-header">
                <h2>{{ 'dashboard.recent_projects_section.title'|trans }}</h2>
                <a href="{{ path('app_project_index') }}" class="link-more">
                    {{ 'dashboard.recent_projects_section.see_all'|trans }}
                    {{ ux_icon('lucide:arrow-right', {class: 'icon-3xs'}) }}
                </a>
            </div>

            <div class="sc-cards-grid">
                {% if projects is empty %}
                    <p class="text-muted">{{ 'dashboard.projects.empty'|trans }}</p>
                {% else %}
                    {% for project in projects|slice(0, 4) %}
                        {{ include('workshop/_partials/_project_card_private.html.twig', {
                            project: project,
                            role: 'owner',
                        }) }}
                    {% endfor %}
                {% endif %}
            </div>

            {% if projects|length > 4 %}
                <div class="load-more-container">
                    <a href="{{ path('app_project_index') }}" class="btn-load-more">
                        {{ ux_icon('lucide:chevron-down', {width: 18, height: 18}) }}
                        {{ 'dashboard.recent_projects_section.see_more'|trans }}
                    </a>
                </div>
            {% endif %}
        </section>

    </div>
{% endblock %}
