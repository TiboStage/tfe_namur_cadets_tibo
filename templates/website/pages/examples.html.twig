{% extends 'website/layout.html.twig' %}
{% trans_default_domain 'website' %}

{% block title %}{{ 'meta.examples_title'|trans }}{% endblock %}

{% block content %}
    <main class="container examples-page section-header">

        {# En-tête de la page #}
        <div class="examples-header">
            <span class="section-tag">{{ 'examples.header.tag'|trans }}</span>
            <h1 class="main-title">
                {{ 'examples.header.title'|trans }} <br>
                <span class="highlight">SCÉNART</span>
            </h1>
            <p class="section-desc">
                {{ 'examples.header.description'|trans }}
            </p>
        </div>

        {# Filtres (Catégories) #}
        <div class="filter-container">
            <button class="filter-btn active" data-filter="all">{{ 'examples.filters.all'|trans }}</button>
            <button class="filter-btn" data-filter="cinema">{{ 'examples.filters.cinema'|trans }}</button>
            <button class="filter-btn" data-filter="serie">{{ 'examples.filters.serie'|trans }}</button>
            <button class="filter-btn" data-filter="jeu-video">{{ 'examples.filters.video_game'|trans }}</button>
        </div>

        {# Grille de projets (Vide pour l'instant ou avec des placeholders) #}
        <div class="projects-grid">
            {# On peut boucler ici sur des exemples si tu en as en DB ou en dur #}
            <div class="no-items">
                <p>{{ 'examples.grid.empty_message'|trans }}</p>
            </div>
        </div>

    </main>
{% endblock %}
